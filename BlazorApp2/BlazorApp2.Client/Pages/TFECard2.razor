@using ClassLibrary.Shared

@* Aumentamos el ancho a 450px y quitamos el estilo rígido para que sea más flexible *@
<MudCard Elevation="4" Style="max-width: 450px; width: 100%; border-radius: 20px; overflow: hidden;" Class="mx-auto">

    <MudCardMedia Image="@Propuesta.ImagenUrl" Height="220" />

    <MudCardContent Class="px-6">
        @* Añadimos un poco más de padding lateral *@

        @* Título y Fecha de publicación *@
        <div class="d-flex justify-space-between align-start mb-1">
            <MudText Typo="Typo.h5" Style="font-weight: bold; line-height: 1.2;">@Propuesta.Titulo</MudText>
        </div>

        @* Info del Tutor y Fecha de Posteo *@
        <div class="d-flex justify-space-between align-center mb-4">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Tutor: @Propuesta.Tutor</MudText>
            <MudChip T="string" Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Variant="Variant.Text">
                @Propuesta.FechaPublicacion.ToString("dd MMM yyyy")
            </MudChip>
        </div>

        @* Badge de Duración y Tags *@
        <div class="d-flex align-center gap-2 mb-3">
            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Color="Color.Info" />
            <MudText Typo="Typo.caption" Style="font-weight: 500;">Estimado: @Propuesta.DuracionEstimada</MudText>
        </div>

        <div class="d-flex flex-wrap gap-1 mb-4">
            @foreach (var tag in Propuesta.Topics)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Label="true">@tag</MudChip>
            }
        </div>

        <MudDivider Class="my-3" />

        @* Descripción *@
        <MudText Typo="Typo.body2" Style="height: 65px; overflow: hidden; color: #555;">
            @Propuesta.DescripcionCorta
        </MudText>

        @* Indicador de Caducidad *@
        <div class="mt-4">
            @{
                var diasRestantes = (Propuesta.FechaExpiracion - DateTime.Now).Days;
                var colorBarra = diasRestantes < 7 ? Color.Error : Color.Success;
            }
            <div class="d-flex justify-space-between mb-1">
                <MudText Typo="Typo.caption" Color="@colorBarra" Style="font-weight: bold;">
                    @(diasRestantes > 0 ? $"Expira en {diasRestantes} días" : "¡Expirado!")
                </MudText>
            </div>
            <MudProgressLinear Color="@colorBarra" Value="@Propuesta.PorcentajeTiempoRestante" Size="Size.Small" />
        </div>
    </MudCardContent>

    <MudCardActions Class="d-flex justify-center gap-10 pb-8 pt-4">
        <MudFab Color="Color.Error" StartIcon="@Icons.Material.Filled.Close" Size="Size.Large" OnClick="HandleReject" />
        <MudFab Color="Color.Success" StartIcon="@Icons.Material.Filled.Favorite" Size="Size.Large" OnClick="HandleAccept" />
    </MudCardActions>
</MudCard>

@code {
    [Parameter, EditorRequired] public PropuestaTfgDto Propuesta { get; set; } = new();
    [Parameter] public EventCallback<PropuestaTfgDto> OnAccept { get; set; }
    [Parameter] public EventCallback<PropuestaTfgDto> OnReject { get; set; }

    private async Task HandleAccept() => await OnAccept.InvokeAsync(Propuesta);
    private async Task HandleReject() => await OnReject.InvokeAsync(Propuesta);
}