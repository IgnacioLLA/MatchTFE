@using TFELibrary.Shared

<MudCard Elevation="4" Style="width: 350px; border-radius: 20px; overflow: hidden; position: relative;">

    @* 1. Imagen de Cabecera *@
    <MudCardMedia Image="@Propuesta.ImagenUrl" Height="200" />

    <MudCardContent>
        @* 2. Título del TFE *@
        <MudText Typo="Typo.h5" Style="font-weight: bold;">@Propuesta.Titulo</MudText>

        @* 3. Nombre del Tutor *@
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">Tutor: @Propuesta.Tutor</MudText>

        @* 4. Badge de Duración *@
        <div class="d-flex align-center mb-3">
            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Class="mr-1" Color="Color.Info" />
            <MudText Typo="Typo.caption">@Propuesta.DuracionEstimada</MudText>
        </div>

        @* 5. Contenedor de Tags (Topics) *@
        <div class="d-flex flex-wrap gap-1 mb-3">
            @foreach (var tag in Propuesta.Topics)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Class="ma-0">#@tag</MudChip>
            }
        </div>

        @* 6. Descripción Corta (Trincada a 3 líneas) *@
        <MudText Typo="Typo.body2" Style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; height: 60px;">
            @Propuesta.DescripcionCorta
        </MudText>

        @* 7. Indicador de Caducidad *@
        <div class="mt-4">
            @{
                var diasRestantes = (Propuesta.FechaExpiracion - DateTime.Now).Days;
                var colorBarra = diasRestantes < 7 ? Color.Error : Color.Success;
            }
            <div class="d-flex justify-space-between mb-1">
                <MudText Typo="Typo.caption" Color="@colorBarra">Expira en @diasRestantes días</MudText>
            </div>
            <MudProgressLinear Color="@colorBarra" Value="@Propuesta.PorcentajeTiempoRestante" Class="my-1" />
        </div>
    </MudCardContent>

    @* Botones tipo Tinder (Simulados) *@
    <MudCardActions Class="d-flex justify-center gap-6 pb-6">

        @* Botón de Rechazar (X) *@
        <MudFab Color="Color.Error"
                StartIcon="@Icons.Material.Filled.Close"
                Size="Size.Large"
                OnClick="HandleReject"
                Shadow="true" />

        @* Botón de Aceptar (Corazón) *@
        <MudFab Color="Color.Success"
                StartIcon="@Icons.Material.Filled.Favorite"
                Size="Size.Large"
                OnClick="HandleAccept"
                Shadow="true" />

    </MudCardActions>
</MudCard>

@code {
    [Parameter, EditorRequired] public PropuestaTfgDto Propuesta { get; set; } = new();

    // Definimos los eventos que el Padre podrá escuchar
    [Parameter] public EventCallback<PropuestaTfgDto> OnAccept { get; set; }
    [Parameter] public EventCallback<PropuestaTfgDto> OnReject { get; set; }

    private async Task HandleAccept() => await OnAccept.InvokeAsync(Propuesta);
    private async Task HandleReject() => await OnReject.InvokeAsync(Propuesta);
}