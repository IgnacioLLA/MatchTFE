@using MudBlazor
@using TFELibrary.Shared

@inject IStringLocalizer<SharedResources> L

<MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-2 animate-fade-in">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudIcon Icon="@Icons.Material.Filled.Work" Color="Color.Tertiary" />
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudText Typo="Typo.h6" Class="font-weight-bold">@L["Profile_TeacherAcademicData"]</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudGrid Class="mb-2">
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Model.Department"
                              Label="@L["Profile_Department"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="rounded-lg"
                              HelperText="@L["Profile_DepartmentHelper"]"
                              Placeholder="@L["Profile_DepartmentPlaceholder"]" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Model.OfficeLocation"
                              Label="@L["Profile_Office"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="rounded-lg"
                              HelperText="@L["Profile_OfficeHelper"]"
                              Placeholder="@L["Profile_OfficePlaceholder"]" />
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public ProfileDto Model { get; set; } = default!;
}
