@using MudBlazor

<MudChip T="string"
         Variant="Variant.Text"
         Color="Color.Primary"
         OnClose="RemoveTag"
         CloseIcon="@Icons.Material.Filled.Close"
         Size="Size.Medium"
         Class="mr-2 mb-2">
    @Text
</MudChip>

@code {
    [Parameter]
    public string Text { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnRemoved { get; set; }

    private async Task RemoveTag()
    {
        if (OnRemoved.HasDelegate)
        {
            await OnRemoved.InvokeAsync(Text);
        }
    }
}