@using TFELibrary.Shared

@inject IStringLocalizer<SharedResources> L

<MudPaper Elevation="0" Class="pa-6 rounded-xl border-all mb-6">
    <MudGrid>
        <MudItem xs="12" md="9">
            <MudText Typo="Typo.h5" Class="app-title-tight mb-4">
                @Tfe.Title
            </MudText>

            @if (Tfe.Topics != null && Tfe.Topics.Any())
            {
                <div class="d-flex flex-wrap gap-2 mb-6">
                    @foreach (var topic in Tfe.Topics)
                    {
                        <MudChip T="string" Size="Size.Small" Class="rounded-lg px-3 tag-chip">
                            @topic.Name
                        </MudChip>
                    }
                </div>
            }

            <div class="d-flex align-center mb-2 app-text-muted">
                <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" Class="mr-2" />
                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@L["TfeSummary_RequiredSkills"]</MudText>
            </div>

            @if (Tfe.RequiredSkills != null && Tfe.RequiredSkills.Any())
            {
                <ul class="app-text-reading pl-8 mb-0 list-disc">
                    @foreach (var skill in Tfe.RequiredSkills)
                    {
                        <li>@skill.Tag</li>
                    }
                </ul>
            }
        </MudItem>

        <MudItem xs="12" md="3" Class="d-flex justify-end align-start">
            <MudPaper Elevation="0" Class="pa-4 rounded-xl d-flex flex-column align-center justify-center border-all w-100 metric-box">
                <MudText Typo="Typo.h3" Color="Color.Primary" Class="font-weight-bold mb-1">
                    @CandidateCount
                </MudText>
                <MudText Typo="Typo.caption" Class="app-text-muted font-weight-bold text-center letter-sp-05">
                    @L["TfeSummary_InterestedCandidates"]
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public TfeDto Tfe { get; set; } = default!;

    [Parameter]
    public int CandidateCount { get; set; }
}
