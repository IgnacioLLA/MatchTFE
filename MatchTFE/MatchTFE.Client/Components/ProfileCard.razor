@using TFELibrary.Shared

<div class="animate-fade-in tfe-card-container">
    <MudGrid Spacing="4" Class="mb-6">

        <MudItem xs="12" md="4">

            <MudPaper Elevation="1" Class="pa-6 rounded-xl border-all mb-4 text-center">
                <MudAvatar Size="Size.Large" Class="avatar-xl mb-4 mx-auto" Color="Color.Primary" Variant="Variant.Filled">
                    @if (!string.IsNullOrWhiteSpace(Profile.AvatarUrl))
                    {
                        <MudImage Src="@Profile.AvatarUrl" Alt="@Profile.FirstName" />
                    }
                    else
                    {
                        <span class="font-weight-bold text-h4">@Profile.FirstName.FirstOrDefault()</span>
                    }
                </MudAvatar>

                <MudText Typo="Typo.h5" Class="font-weight-bold">@Profile.FirstName @Profile.LastName</MudText>

                <MudText Typo="Typo.body2" Color="Color.Primary" Class="mb-4 font-weight-bold">
                    @GetRoleSubtitle(Profile)
                </MudText>

                <div class="d-flex justify-center align-center gap-4 mud-text-secondary">
                    @if (Profile.Role == RoleType.Teacher)
                    {
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-1" />
                            <MudText Typo="Typo.caption">
                                @(string.IsNullOrWhiteSpace(Profile.OfficeLocation) ? "Despacho no establecido" : Profile.OfficeLocation)
                            </MudText>
                        </div>
                    }
                    else if (Profile.Role == RoleType.Student)
                    {
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Small" Class="mr-1" />
                            <MudText Typo="Typo.caption">
                                @(string.IsNullOrWhiteSpace(Profile.AcademicYear) ? "Año no establecido" : Profile.AcademicYear)
                            </MudText>
                        </div>
                    }
                    else if (Profile.Role == RoleType.Admin)
                    {
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" Class="mr-1" />
                            <MudText Typo="Typo.caption">Administrador del sistema</MudText>
                        </div>
                    }
                </div>
            </MudPaper>

            @if (Profile.Role == RoleType.Student)
            {
                <MudPaper Elevation="1" Class="pa-6 rounded-xl border-all">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.h6" Class="font-weight-bold">Competencias Técnicas</MudText>
                    </div>

                    @if (Profile.Skills != null && Profile.Skills.Any())
                    {
                        @foreach (var skill in Profile.Skills)
                        {
                            <div class="d-flex align-center justify-space-between pa-3 border-all rounded-lg mb-3 chip-surface">
                                <MudText Typo="Typo.body2" Class="chip-text font-weight-bold">@skill.Tag</MudText>
                                <MudRating SelectedValue="@skill.Level" MaxValue="5" Color="Color.Primary" Size="Size.Small" ReadOnly="true" />
                            </div>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No tiene competencias establecidas.</MudText>
                    }
                </MudPaper>
            }
        </MudItem>

        <MudItem xs="12" md="8">

            <MudPaper Elevation="1" Class="pa-6 rounded-xl border-all mb-4">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Primary" Class="mr-2" />
                    <MudText Typo="Typo.h6" Class="font-weight-bold">Áreas de Interés</MudText>
                </div>

                @if (Profile.Interests != null && Profile.Interests.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var interest in Profile.Interests)
                        {
                            <ChipTag Text="@interest" ShowCloseIcon="false" />
                        }
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">No tiene áreas de interés establecidas.</MudText>
                }
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-6 rounded-xl border-all">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Primary" Class="mr-2" />
                    <MudText Typo="Typo.h6" Class="font-weight-bold">Biografía y Motivación</MudText>
                </div>

                @if (!string.IsNullOrWhiteSpace(Profile.Bio))
                {
                    <MudText Typo="Typo.body1" Class="mud-text-secondary app-text-reading">
                        @Profile.Bio
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">No tiene biografía establecida.</MudText>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@code {
    [Parameter, EditorRequired]
    public ProfileDto Profile { get; set; } = default!;

    private static string GetRoleSubtitle(ProfileDto profile) => profile.Role switch
    {
        RoleType.Teacher => string.IsNullOrWhiteSpace(profile.Department) ? "Departamento no establecido" : profile.Department,
        RoleType.Student => "Estudiante",
        RoleType.Admin => "Administrador del sistema",
        _ => profile.Role.ToString()
    };
}