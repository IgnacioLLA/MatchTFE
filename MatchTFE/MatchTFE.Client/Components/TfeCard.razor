@using TFELibrary.Shared

@inject IStringLocalizer<SharedResources> L

<div class="animate-fade-in tfe-card-container">
    <MudPaper Elevation="1" Class="pa-6 pa-sm-10 rounded-xl border-all mb-6">
        <MudGrid Spacing="4">

            <MudItem xs="12" md="5" Class="d-flex justify-center align-center">
                <MudPaper Elevation="0" Class="app-icon-box rounded-xl d-flex align-center justify-center">
                    <div class="relative d-flex align-center justify-center">
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="icon-hero" Color="Color.Primary" />
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudText Typo="Typo.h5" Class="app-title-tight mb-4">@Proposal.Title</MudText>

                <div class="d-flex align-center mb-6">
                    <MudAvatar Size="Size.Medium" Class="mr-3" Color="Color.Primary">
                        @(string.IsNullOrWhiteSpace(Proposal.TutorName) ? "T" : Proposal.TutorName[0].ToString())
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.body2" Class="font-weight-bold">@Proposal.TutorName</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@L["TfeCard_Tutor"]</MudText>
                    </div>
                </div>

                @if (Proposal.Topics != null && Proposal.Topics.Any())
                {
                    <div class="d-flex flex-wrap gap-2 mb-8">
                        @foreach (var topic in Proposal.Topics)
                        {
                            <ChipTag Text="@topic.Name" ShowCloseIcon="false" />
                        }
                    </div>
                }

                <MudGrid Spacing="3">
                    <MudItem xs="6">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Outlined.Timer" Size="Size.Small" Class="mr-2 mud-text-secondary" />
                            <div>
                                <MudText Typo="Typo.caption" Class="app-caption-uppercase mud-text-secondary">@L["TfeCard_EstimatedDuration"]</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@GetDurationText()</MudText>
                            </div>
                        </div>
                    </MudItem>
                    <MudItem xs="6">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Outlined.CalendarToday" Size="Size.Small" Class="mr-2 mud-text-secondary" />
                            <div>
                                <MudText Typo="Typo.caption" Class="app-caption-uppercase mud-text-secondary">@L["TfeCard_Deadline"]</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-bold">
                                    @(Proposal.ExpirationDate != default ? Proposal.ExpirationDate.ToString("dd MMM, yyyy") : L["TfeCard_NoDate"].Value)
                                </MudText>
                            </div>
                        </div>
                    </MudItem>
                </MudGrid>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-6 pa-sm-10 rounded-xl border-all mb-6">
        <div class="d-flex align-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Class="mr-3" />
            <MudText Typo="Typo.h6"><b>@L["TfeCard_ProjectDescription"]</b></MudText>
        </div>
        <MudText Typo="Typo.body1" Class="app-text-reading mb-4">
            @Proposal.Description
        </MudText>
    </MudPaper>

    @if (Proposal.RequiredSkills != null && Proposal.RequiredSkills.Any())
    {
        <MudPaper Elevation="1" Class="pa-6 pa-sm-10 rounded-xl border-all mb-6">
            <div class="d-flex align-center mb-6">
                <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Primary" Class="mr-3" />
                <MudText Typo="Typo.h6"><b>@L["TfeCard_TechnicalRequirements"]</b></MudText>
            </div>

            <div class="d-flex flex-wrap gap-4">
                @foreach (var skill in Proposal.RequiredSkills)
                {
                                <div class="d-flex align-center justify-space-between pa-3 border-all rounded-lg chip-surface-primary chip-min-200">
                        <MudText Typo="Typo.body2" Class="font-weight-bold mr-4" Color="Color.Primary">@skill.Tag</MudText>
                        <MudRating SelectedValue="@skill.Level" MaxValue="5" Color="Color.Primary" Size="Size.Small" ReadOnly="true" />
                    </div>
                }
            </div>
        </MudPaper>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public TfeDto Proposal { get; set; } = default!;

    private string GetDurationText()
    {
        if (Proposal.EstimatedDelivery == default) return L["TfeCard_DurationNotSpecified"].Value;

        var months = ((Proposal.EstimatedDelivery.Year - DateTime.Today.Year) * 12) +
                       Proposal.EstimatedDelivery.Month - DateTime.Today.Month;

        return months > 0
            ? L["TfeCard_DurationMonths", months].Value
            : L["TfeCard_DurationLessThan1Month"].Value;
    }
}
