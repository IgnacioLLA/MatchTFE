@using TFELibrary.Shared

<div class="animate-fade-in tfe-card-container">
    <MudPaper Elevation="1" Class="pa-6 pa-sm-10 rounded-xl bg-white border-all mb-6">
        <MudGrid Spacing="4">

            <MudItem xs="12" md="5" Class="d-flex justify-center align-center">
                <MudPaper Elevation="0" Class="app-icon-box rounded-xl d-flex align-center justify-center">
                    <div class="relative d-flex align-center justify-center">
                        <MudIcon Icon="@GetIcon(Proposal.IconName)" Class="icon-hero" Color="Color.Primary" />
                        <MudPaper Elevation="0" Class="pa-2 absolute rounded-lg border-all bg-white code-icon-badge">
                            <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Color="Color.Primary" />
                        </MudPaper>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudText Typo="Typo.h5" Class="app-title-tight mb-4">@Proposal.Title</MudText>

                <div class="d-flex align-center mb-6">
                    <MudAvatar Size="Size.Medium" Class="mr-3">@Proposal.TutorName[0]</MudAvatar>
                    <div>
                        <MudText Typo="Typo.body2" Class="font-weight-bold">@Proposal.TutorName</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@Proposal.Department</MudText>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mb-8">
                    @foreach (var tech in Proposal.Technologies)
                    {
                        <MudChip T="string" Variant="Variant.Text" Color="Color.Primary" Size="Size.Medium" Class="px-4 py-2 font-weight-bold">@tech</MudChip>
                    }
                </div>

                <MudGrid Spacing="3">
                    <MudItem xs="6">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Outlined.Timer" Size="Size.Small" Class="mr-2 mud-text-secondary" />
                            <div>
                                <MudText Typo="Typo.caption" Class="app-caption-uppercase mud-text-secondary">Duración</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@Proposal.EstimatedDuration</MudText>
                            </div>
                        </div>
                    </MudItem>
                    <MudItem xs="6">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Outlined.CalendarToday" Size="Size.Small" Class="mr-2 mud-text-secondary" />
                            <div>
                                <MudText Typo="Typo.caption" Class="app-caption-uppercase mud-text-secondary">Fecha Caducidad</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@Proposal.ExpirationDate.ToString("dd MMMM, yyyy")</MudText>
                            </div>
                        </div>
                    </MudItem>
                </MudGrid>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-6 pa-sm-10 rounded-xl bg-white border-all mb-10">
        <div class="d-flex align-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Class="mr-3" />
            <MudText Typo="Typo.h6"><b>Descripción del Proyecto</b></MudText>
        </div>

        <MudText Typo="Typo.body1" Class="app-text-reading mb-4">
            @Proposal.Description
        </MudText>
    </MudPaper>

    <MudPaper Elevation="0" Class="pa-4 rounded-xl app-actions-bar border-all">
        <div class="d-flex flex-column flex-sm-row align-center justify-center gap-3">
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Large"
                       OnClick="@(() => OnDecision.InvokeAsync(false))"
                       Class="rounded-lg px-8 py-3 font-weight-bold w-100 w-sm-auto" StartIcon="@Icons.Material.Filled.Close">
                DESCARTAR
            </MudButton>

            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large"
                       OnClick="@(() => OnDecision.InvokeAsync(true))"
                       Class="rounded-lg px-8 py-3 font-weight-bold w-100 w-sm-auto" StartIcon="@Icons.Material.Filled.Favorite">
                ME INTERESA
            </MudButton>
        </div>
    </MudPaper>
</div>

<style>
    .code-icon-badge {
        bottom: 10px;
        right: -10px;
    }
</style>

@code {
    [Parameter, EditorRequired] public TfeProposalDto Proposal { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnDecision { get; set; }

    private string GetIcon(string iconName)
    {
        return iconName switch
        {
            "Security" => Icons.Material.Filled.Security,
            "LocalShipping" => Icons.Material.Filled.LocalShipping,
            _ => Icons.Material.Filled.Psychology
        };
    }
}