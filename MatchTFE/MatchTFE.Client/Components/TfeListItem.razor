@using TFELibrary.Shared

<div class="d-flex align-center py-4 border-b-default">
    <MudGrid Class="align-center w-100" Spacing="2">

        @* TITLE *@
        <MudItem xs="12" md="3">
            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-1">
                @Model.Title
            </MudText>
        </MudItem>

        @* STATUS *@
        <MudItem xs="6" md="2">
            <MudChip T="string"
                     Size="Size.Small"
                     Color="@GetStatusColor(Model.Status)"
                     Variant="@GetStatusVariant(Model.Status)"
                     Class="font-weight-bold px-3">
                @GetStatusText(Model.Status)
            </MudChip>
        </MudItem>

        @* EXPDATE *@
        <MudItem xs="12" md="2" Class="d-none d-md-flex align-center">
            <div class="d-flex align-center mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-2" />
                <MudText Typo="Typo.body2">
                    @(Model.ExpirationDate != default ? Model.ExpirationDate.ToString("dd MMM, yyyy") : "Sin fecha")
                </MudText>
            </div>
        </MudItem>

        @* INTEREST *@
        <MudItem xs="12" md="2" Class="d-none d-md-flex align-center">
            <div class="d-flex align-center gap-3">
                <div class="d-flex align-center @(Model.InterestedAmount > 0 ? "mud-text-primary" : "mud-text-secondary")">
                    <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Class="mr-1" />
                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                        @Model.InterestedAmount
                    </MudText>
                </div>

                @if (Model.InterestedAmount > 0)
                {
                    <MudButton Variant="Variant.Text"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Href="@($"/tfe/{Model.Id}/candidates")"
                               Class="font-weight-bold px-2 py-0">
                        Ver
                    </MudButton>
                }
            </div>
        </MudItem>

        @* CREATION DATE *@
        <MudItem xs="12" md="2" Class="d-none d-md-flex align-center">
            <div class="d-flex align-center mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Size="Size.Small" Class="mr-2" />
                <MudText Typo="Typo.body2">
                    @(Model.CreationDate != default ? Model.CreationDate.ToString("dd MMM, yyyy") : "Sin fecha")
                </MudText>
            </div>
        </MudItem>

        @* ACTIONS *@
        <MudItem xs="6" md="1" Class="d-flex justify-end align-center gap-1">
            @if (Model.Status != TFEStatus.Cancelled)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Size="Size.Small"
                               Color="Color.Default"
                               Href="@($"/tfe/edit/{Model.Id}")" />

                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Size="Size.Small"
                               Color="Color.Error"
                               OnClick="OnDeleteClicked" />
            }
        </MudItem>
    </MudGrid>
</div>

@code {
    [Parameter, EditorRequired]
    public TfeDto Model { get; set; } = default!;

    [Parameter]
    public EventCallback<int> OnDeleted { get; set; }

    private async Task OnDeleteClicked()
    {
        if (OnDeleted.HasDelegate)
        {
            await OnDeleted.InvokeAsync(Model.Id);
        }
    }

    private Color GetStatusColor(TFEStatus status) => status switch
    {
        TFEStatus.Completed => Color.Success,
        TFEStatus.Open => Color.Default,
        TFEStatus.Cancelled => Color.Info,
        _ => Color.Default
    };

    private Variant GetStatusVariant(TFEStatus status) => status switch
    {
        TFEStatus.Completed => Variant.Filled,
        TFEStatus.Open => Variant.Outlined,
        TFEStatus.Cancelled => Variant.Filled,
        _ => Variant.Filled
    };

    private string GetStatusText(TFEStatus status) => status switch
    {
        TFEStatus.Completed => "• Completado",
        TFEStatus.Open => "• Abierto",
        TFEStatus.Cancelled => "• Cancelado",
        _ => status.ToString()
    };
}