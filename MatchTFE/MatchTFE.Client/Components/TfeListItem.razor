@using TFELibrary.Shared

@inject IStringLocalizer<SharedResources> L

<div class="d-flex align-center py-4 border-b-default">
    <MudGrid Class="align-center w-100" Spacing="2">

        @* TITLE *@
        <MudItem xs="12" md="3">
            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-1">
                @Model.Title
            </MudText>
        </MudItem>

        @* STATUS *@
        <MudItem xs="6" md="2">
            <MudChip T="string"
                     Size="Size.Small"
                     Color="@GetStatusColor(Model.Status)"
                     Variant="@GetStatusVariant(Model.Status)"
                     Class="font-weight-bold px-3">
                @GetStatusText(Model.Status)
            </MudChip>
        </MudItem>

        @* EXPDATE *@
        <MudItem xs="12" md="2" Class="d-none d-md-flex align-center">
            <div class="d-flex flex-column">
                <div class="d-flex align-center mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-2" />
                    <MudText Typo="Typo.body2">
                        @(Model.ExpirationDate != default ? Model.ExpirationDate.ToString("dd MMM, yyyy") : L["MyTfes_NoDate"].Value)
                    </MudText>
                </div>

                <MudChip T="string"
                         Size="Size.Small"
                         Color="@GetExpirationStatusColor(Model.ExpirationDate)"
                         Variant="Variant.Filled"
                         Class="mt-2 font-weight-bold px-3 align-self-start">
                    @GetExpirationStatusText(Model.ExpirationDate)
                </MudChip>
            </div>
        </MudItem>

        @* INTEREST *@
        <MudItem xs="12" md="2" Class="d-none d-md-flex align-center">
            <div class="d-flex align-center gap-3">
                <div class="d-flex align-center @(Model.InterestedAmount > 0 ? "mud-text-primary" : "mud-text-secondary")">
                    <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Class="mr-1" />
                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                        @Model.InterestedAmount
                    </MudText>
                </div>

                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Href="@($"/tfe/{Model.Id}/candidates")"
                           Class="font-weight-bold px-2 py-0">
                    @L["TfeListItem_ViewBtn"]
                </MudButton>
            </div>
        </MudItem>

        @* CREATION DATE *@
        <MudItem xs="12" md="2" Class="d-none d-md-flex align-center">
            <div class="d-flex align-center mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Size="Size.Small" Class="mr-2" />
                <MudText Typo="Typo.body2">
                    @(Model.CreationDate != default ? Model.CreationDate.ToString("dd MMM, yyyy") : L["MyTfes_NoDate"].Value)
                </MudText>
            </div>
        </MudItem>

        @* ACTIONS *@
        <MudItem xs="6" md="1" Class="d-flex justify-end align-center gap-1">
            @if (Model.Status != TfeStatus.Cancelled)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Size="Size.Small"
                               Color="Color.Default"
                               Href="@($"/tfe/edit/{Model.Id}")" />

                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Size="Size.Small"
                               Color="Color.Error"
                               OnClick="OnDeleteClicked" />
            }
        </MudItem>
    </MudGrid>
</div>

@code {
    [Parameter, EditorRequired]
    public TfeDto Model { get; set; } = default!;

    [Parameter]
    public EventCallback<int> OnDeleted { get; set; }

    private async Task OnDeleteClicked()
    {
        if (OnDeleted.HasDelegate)
        {
            await OnDeleted.InvokeAsync(Model.Id);
        }
    }

    private Color GetStatusColor(TfeStatus status) => status switch
    {
        TfeStatus.Completed => Color.Success,
        TfeStatus.Open => Color.Default,
        TfeStatus.Cancelled => Color.Info,
        _ => Color.Default
    };

    private Variant GetStatusVariant(TfeStatus status) => status switch
    {
        TfeStatus.Completed => Variant.Filled,
        TfeStatus.Open => Variant.Outlined,
        TfeStatus.Cancelled => Variant.Filled,
        _ => Variant.Filled
    };

    private string GetStatusText(TfeStatus status) => status switch
    {
        TfeStatus.Completed => L["TfeStatus_Completed"].Value,
        TfeStatus.Open => L["TfeStatus_Open"].Value,
        TfeStatus.Cancelled => L["TfeStatus_Cancelled"].Value,
        _ => status.ToString()
    };

    private static bool IsExpired(DateTime expirationDate)
    {
        return expirationDate != default && expirationDate.Date < DateTime.Today;
    }

    private Color GetExpirationStatusColor(DateTime expirationDate) => IsExpired(expirationDate) ? Color.Error : Color.Success;

    private string GetExpirationStatusText(DateTime expirationDate) =>
        IsExpired(expirationDate) ? L["TfeStatus_Expired"].Value : L["TfeStatus_Active"].Value;
}
