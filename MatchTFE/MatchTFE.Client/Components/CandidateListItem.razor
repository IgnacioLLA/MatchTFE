@using TFELibrary.Shared

<MudPaper Elevation="0" Class="pa-4 rounded-xl border-all mb-4 d-flex flex-column flex-md-row align-center justify-space-between gap-4 transition-all hover-shadow">

    @* Info *@
    <div class="d-flex align-center w-100">
        <MudAvatar Size="Size.Large" Class="mr-4" Color="Color.Primary" Variant="Variant.Filled">
            @if (!string.IsNullOrWhiteSpace(Candidate.Profile.AvatarUrl))
            {
                <MudImage Src="@Candidate.Profile.AvatarUrl" Alt="@Candidate.Profile.FirstName" />
            }
                else
                {
                    <span class="font-weight-bold candidate-initial">@Candidate.Profile.FirstName.FirstOrDefault()</span>
                }
        </MudAvatar>

        <div>
            <MudText Typo="Typo.h6" Class="font-weight-bold text-main line-tight">
                @Candidate.Profile.FirstName @Candidate.Profile.LastName
            </MudText>

            <MudText Typo="Typo.body2" Class="app-text-muted mt-1">
                @GetProfileSubtitle(Candidate.Profile)
            </MudText>
        </div>
    </div>

    @* Actions *@
    <div class="d-flex align-center gap-3 w-100 justify-md-end">
        <MudChip T="string" Size="Size.Small" Color="@(Candidate.CanDecide ? Color.Info : Color.Secondary)" Variant="Variant.Filled">
            @(Candidate.CanDecide ? "Pendiente" : Candidate.Status.ToString())
        </MudChip>

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   Class="rounded-lg font-weight-bold px-4"
                   OnClick="() => OnViewProfile.InvokeAsync(Candidate)">
            Ver Perfil
        </MudButton>

        <MudIconButton Icon="@Icons.Material.Filled.Close"
                   Variant="Variant.Outlined"
                   Color="Color.Error"
                   Class="rounded-lg border-error"
                   Disabled="@(!Candidate.CanDecide)"
                   OnClick="() => OnReject.InvokeAsync(Candidate)" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   Class="rounded-lg font-weight-bold px-6"
                   Disabled="@(!Candidate.CanDecide)"
                   OnClick="() => OnAccept.InvokeAsync(Candidate)">
            Me interesa
        </MudButton>
    </div>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public TfeCandidateDto Candidate { get; set; } = default!;

    [Parameter] public EventCallback<TfeCandidateDto> OnViewProfile { get; set; }
    [Parameter] public EventCallback<TfeCandidateDto> OnReject { get; set; }
    [Parameter] public EventCallback<TfeCandidateDto> OnAccept { get; set; }

    private static RenderFragment GetProfileSubtitle(ProfileDto profile) => builder =>
    {
        var content = profile.Role switch
        {
            RoleType.Teacher => string.IsNullOrWhiteSpace(profile.Department) ? "Departamento no establecido" : profile.Department,
            RoleType.Student => string.IsNullOrWhiteSpace(profile.AcademicYear) ? "Año no establecido" : profile.AcademicYear,
            RoleType.Admin => "Administrador del sistema",
            _ => profile.Role.ToString()
        };

        var icon = profile.Role switch
        {
            RoleType.Teacher => Icons.Material.Filled.Business,
            RoleType.Student => Icons.Material.Filled.School,
            RoleType.Admin => Icons.Material.Filled.AdminPanelSettings,
            _ => Icons.Material.Filled.Badge
        };

        builder.OpenComponent<MudIcon>(0);
        builder.AddAttribute(1, "Icon", icon);
        builder.AddAttribute(2, "Size", Size.Small);
        builder.AddAttribute(3, "Class", "mr-1");
        builder.AddAttribute(4, "Style", "vertical-align: sub;");
        builder.CloseComponent();

        builder.AddContent(5, content);
    };
}