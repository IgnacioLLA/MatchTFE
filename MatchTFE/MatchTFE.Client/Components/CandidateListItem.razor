@using TFELibrary.Shared

@inject IStringLocalizer<SharedResources> L

<MudPaper Elevation="0" Class="pa-4 rounded-xl border-all mb-4 d-flex flex-column flex-md-row align-center justify-space-between gap-4 transition-all hover-shadow">

    @* Info *@
    <div class="d-flex align-center w-100">
        <MudAvatar Size="Size.Large" Class="mr-4" Color="Color.Primary" Variant="Variant.Filled">
            <span class="font-weight-bold candidate-initial">@Candidate.Profile.FirstName.FirstOrDefault()</span>
        </MudAvatar>

        <div>
            <MudText Typo="Typo.h6" Class="font-weight-bold text-main line-tight">
                @Candidate.Profile.FirstName @Candidate.Profile.LastName
            </MudText>

            <MudText Typo="Typo.body2" Class="app-text-muted mt-1">
                @GetProfileSubtitle(Candidate.Profile)
            </MudText>
        </div>
    </div>

    @* Actions *@
    <div class="d-flex align-center gap-3 w-100 justify-md-end">
        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(Candidate.Status)" Variant="Variant.Filled">
            @GetStatusLabel(Candidate.Status)
        </MudChip>

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   Class="rounded-lg font-weight-bold px-4"
                   OnClick="() => OnViewProfile.InvokeAsync(Candidate)">
            @L["CandidateListItem_ViewProfile"]
        </MudButton>

        @if (Candidate.CanDecide && !IsActionsDisabled)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       Class="rounded-lg font-weight-bold px-4"
                       OnClick="() => OnReject.InvokeAsync(Candidate)">
                @L["CandidateListItem_Reject"]
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       Class="rounded-lg font-weight-bold px-6"
                       OnClick="() => OnAccept.InvokeAsync(Candidate)">
                @L["CandidateListItem_Accept"]
            </MudButton>
        }
    </div>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public TfeCandidateDto Candidate { get; set; } = default!;

    [Parameter] public EventCallback<TfeCandidateDto> OnViewProfile { get; set; }
    [Parameter] public EventCallback<TfeCandidateDto> OnReject { get; set; }
    [Parameter] public EventCallback<TfeCandidateDto> OnAccept { get; set; }
    [Parameter] public bool IsActionsDisabled { get; set; } = false;

    private string GetStatusLabel(ProposalStatus status) => status switch
    {
        ProposalStatus.Pending  => L["CandidateStatus_Pending"].Value,
        ProposalStatus.Accepted => L["CandidateStatus_Accepted"].Value,
        ProposalStatus.Rejected => L["CandidateStatus_Rejected"].Value,
        ProposalStatus.Expired  => L["CandidateStatus_Expired"].Value,
        _                       => status.ToString()
    };

    private static Color GetStatusColor(ProposalStatus status) => status switch
    {
        ProposalStatus.Pending  => Color.Info,
        ProposalStatus.Accepted => Color.Success,
        ProposalStatus.Rejected => Color.Error,
        _                       => Color.Secondary
    };

    private string GetProfileSubtitle(ProfileDto profile)
    {
        return profile.Role switch
        {
            RoleType.Teacher => string.IsNullOrWhiteSpace(profile.Department)
                ? L["ProfileCard_NoDept"].Value
                : profile.Department,
            RoleType.Student => string.IsNullOrWhiteSpace(profile.AcademicYear)
                ? L["ProfileCard_NoYear"].Value
                : profile.AcademicYear,
            RoleType.Admin => L["ProfileCard_AdminLabel"].Value,
            _ => profile.Role.ToString()
        };
    }
}
