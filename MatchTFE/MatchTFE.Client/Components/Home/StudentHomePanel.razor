@inject IStringLocalizer<SharedResources> L
@using TFELibrary.Shared

<div class="home-panel">
    <HomeHero Tag="@L["StudentHome_Tag"].Value"
              Title="@L["StudentHome_Title"].Value"
              Subtitle="@L["StudentHome_Subtitle"].Value"
              PrimaryText="@L["StudentHome_PrimaryBtn"].Value"
              PrimaryHref="/tfe/feed"
              PrimaryIcon="@Icons.Material.Filled.Explore"
              SecondaryText="@L["StudentHome_SecondaryBtn"].Value"
              SecondaryHref="/match"
              SecondaryIcon="@Icons.Material.Filled.Layers" />

    <MudPaper Elevation="0" Class="home-highlight border-all rounded-xl">
        <MudText Typo="Typo.h6" Class="app-title-tight mb-2">@L["StudentHome_Cta"]</MudText>
        <MudText Typo="Typo.body2" Class="home-highlight__description mb-4">
            @L["StudentHome_CtaDesc"]
        </MudText>
        <MudButton Href="/tfe/create" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddCircleOutline" Class="rounded-lg font-weight-bold">
            @L["StudentHome_CtaBtn"]
        </MudButton>
    </MudPaper>

    <MudPaper Elevation="0" Class="home-how-it-works border-all rounded-xl">
        <MudText Typo="Typo.h6" Class="app-title-tight mb-3">@L["Home_HowItWorks"]</MudText>
        <ol class="how-it-works__list">
            <li><strong>@L["Home_Step1"]</strong> — @L["Home_Step1Desc"]</li>
            <li><strong>@L["Home_Step2"]</strong> — @L["Home_Step2Desc"]</li>
            <li><strong>@L["Home_Step3"]</strong> — @L["Home_Step3Desc"]</li>
            <li><strong>@L["Home_Step4"]</strong> — @L["Home_Step4Desc"]</li>
        </ol>
    </MudPaper>

    <HomeFeatureGrid SectionId="student-capabilities"
                     Title="@L["StudentHome_GridTitle"].Value"
                     Subtitle="@L["StudentHome_GridSubtitle"].Value">
        <MudItem xs="12" md="4">
            <a href="/tfe/feed" class="home-card-link">
                <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                    <MudIcon Icon="@Icons.Material.Filled.AutoStories" Color="Color.Primary" Size="Size.Large" Class="mb-3" />
                    <MudText Typo="Typo.h6" Class="app-title-tight mb-2">@L["StudentHome_Card1"]</MudText>
                    <MudText Typo="Typo.body2" Class="home-card__description">@L["StudentHome_Card1Desc"]</MudText>
                </MudPaper>
            </a>
        </MudItem>

        <MudItem xs="12" md="4">
            <a href="/match" class="home-card-link">
                <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                    <MudIcon Icon="@Icons.Material.Filled.Favorite" Color="Color.Success" Size="Size.Large" Class="mb-3" />
                    <MudText Typo="Typo.h6" Class="app-title-tight mb-2">@L["StudentHome_Card2"]</MudText>
                    <MudText Typo="Typo.body2" Class="home-card__description">@L["StudentHome_Card2Desc"]</MudText>
                </MudPaper>
            </a>
        </MudItem>

        <MudItem xs="12" md="4">
            <a href="/profile" class="home-card-link">
                <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Info" Size="Size.Large" Class="mb-3" />
                    <MudText Typo="Typo.h6" Class="app-title-tight mb-2">@L["StudentHome_Card3"]</MudText>
                    <MudText Typo="Typo.body2" Class="home-card__description">@L["StudentHome_Card3Desc"]</MudText>
                </MudPaper>
            </a>
        </MudItem>
    </HomeFeatureGrid>

    @if (GlobalProfile?.Interests.Count == 0)
    {
        <MudPaper Elevation="0" Class="home-interests-alert border-all rounded-xl">
            <div class="home-interests-alert__inner">
                <MudIcon Icon="@Icons.Material.Filled.TipsAndUpdates" Color="Color.Warning" Size="Size.Large" Class="home-interests-alert__icon" />
                <div>
                    <MudText Typo="Typo.h6" Class="app-title-tight mb-1">@L["StudentHome_InterestsAlert"]</MudText>
                    <MudText Typo="Typo.body2" Class="home-interests-alert__desc mb-3">
                        @L["StudentHome_InterestsAlertDesc"]
                    </MudText>
                    <MudButton Href="/profile" Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Add" Class="rounded-lg font-weight-bold">
                        @L["StudentHome_InterestsAlertBtn"]
                    </MudButton>
                </div>
            </div>
        </MudPaper>
    }
</div>

@code {
    [CascadingParameter] public ProfileDto? GlobalProfile { get; set; }
}
