<div class="home-panel">
    <HomeHero Tag="ESTUDIANTE"
              Title="Convierte tu TFE en una oportunidad real"
              Subtitle="MATCH-TFE te ayuda a descubrir propuestas de TFE, conectar con tutores y seguir tus matches con claridad."
              PrimaryText="Descubrir proyectos"
              PrimaryHref="/tfe/feed"
              PrimaryIcon="@Icons.Material.Filled.Explore"
              SecondaryText="Ver mis matches"
              SecondaryHref="/match"
              SecondaryIcon="@Icons.Material.Filled.Layers" />

    <HomeFeatureGrid SectionId="student-capabilities"
                     Title="Que puedes hacer desde aqui"
                     Subtitle="Navega por propuestas, muestra tu candidatura en segundos y concentra la informacion clave de tu proceso en un solo lugar.">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                <MudIcon Icon="@Icons.Material.Filled.AutoStories" Color="Color.Primary" Size="Size.Large" Class="mb-3" />
                <MudText Typo="Typo.h6" Class="app-title-tight mb-2">Explorar propuestas relevantes</MudText>
                <MudText Typo="Typo.body2" Class="home-card__description">Encuentra propuestas de TFE por tematica, requisitos y estado.</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                <MudIcon Icon="@Icons.Material.Filled.Favorite" Color="Color.Success" Size="Size.Large" Class="mb-3" />
                <MudText Typo="Typo.h6" Class="app-title-tight mb-2">Hacer match con criterio</MudText>
                <MudText Typo="Typo.body2" Class="home-card__description">Muestra tu candidatura de forma guiada y sigue el estado de cada propuesta sin friccion.</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Info" Size="Size.Large" Class="mb-3" />
                <MudText Typo="Typo.h6" Class="app-title-tight mb-2">Potenciar tu perfil</MudText>
                <MudText Typo="Typo.body2" Class="home-card__description">Mejora tu visibilidad para que tus capacidades destaquen frente al profesorado.</MudText>
            </MudPaper>
        </MudItem>
    </HomeFeatureGrid>

    <MudPaper Elevation="0" Class="home-highlight border-all rounded-xl">
        <MudText Typo="Typo.h6" Class="app-title-tight mb-2">Siguiente mejor paso</MudText>
        <MudText Typo="Typo.body2" Class="home-highlight__description mb-4">
            Completa tu perfil y revisa propuestas recientes para aumentar tus posibilidades de lograr un match de calidad.
        </MudText>
        <MudButton Href="/profile" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Class="rounded-lg font-weight-bold">
            Actualizar mi perfil
        </MudButton>
    </MudPaper>
</div>
