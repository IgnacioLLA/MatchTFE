@inject IStringLocalizer<SharedResources> L

<div class="home-panel">
    <HomeHero Tag="@L["TeacherHome_Tag"].Value"
              Title="@L["TeacherHome_Title"].Value"
              Subtitle="@L["TeacherHome_Subtitle"].Value"
              PrimaryText="@L["TeacherHome_PrimaryBtn"].Value"
              PrimaryHref="/tfe/feed"
              PrimaryIcon="@Icons.Material.Filled.Explore"
              SecondaryText="@L["TeacherHome_SecondaryBtn"].Value"
              SecondaryHref="/tfe/author"
              SecondaryIcon="@Icons.Material.Filled.Assignment" />

    <HomeFeatureGrid SectionId="teacher-capabilities"
                     Title="@L["TeacherHome_GridTitle"].Value"
                     Subtitle="@L["TeacherHome_GridSubtitle"].Value">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                <MudIcon Icon="@Icons.Material.Filled.EditNote" Color="Color.Primary" Size="Size.Large" Class="mb-3" />
                <MudText Typo="Typo.h6" Class="app-title-tight mb-2">@L["TeacherHome_Card1"]</MudText>
                <MudText Typo="Typo.body2" Class="home-card__description">@L["TeacherHome_Card1Desc"]</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Info" Size="Size.Large" Class="mb-3" />
                <MudText Typo="Typo.h6" Class="app-title-tight mb-2">@L["TeacherHome_Card2"]</MudText>
                <MudText Typo="Typo.body2" Class="home-card__description">@L["TeacherHome_Card2Desc"]</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Success" Size="Size.Large" Class="mb-3" />
                <MudText Typo="Typo.h6" Class="app-title-tight mb-2">@L["TeacherHome_Card3"]</MudText>
                <MudText Typo="Typo.body2" Class="home-card__description">@L["TeacherHome_Card3Desc"]</MudText>
            </MudPaper>
        </MudItem>
    </HomeFeatureGrid>

    <MudPaper Elevation="0" Class="home-highlight border-all rounded-xl">
        <MudText Typo="Typo.h6" Class="app-title-tight mb-2">@L["TeacherHome_Cta"]</MudText>
        <MudText Typo="Typo.body2" Class="home-highlight__description mb-4">
            @L["TeacherHome_CtaDesc"]
        </MudText>
        <MudButton Href="/tfe/author" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Checklist" Class="rounded-lg font-weight-bold">
            @L["TeacherHome_CtaBtn"]
        </MudButton>
    </MudPaper>
</div>
