<div class="home-panel">
    <HomeHero Tag="PROFESOR"
              Title="Encuentra al candidato ideal para tu TFE"
              Subtitle="Publica y gestiona propuestas con un flujo simple, revisa perfiles compatibles y acelera decisiones con una experiencia centrada en tutorizacion academica."
              PrimaryText="Descubrir proyectos"
              PrimaryHref="/tfe/feed"
              PrimaryIcon="@Icons.Material.Filled.Explore"
              SecondaryText="Ir a mis propuestas"
              SecondaryHref="/tfe/author"
              SecondaryIcon="@Icons.Material.Filled.Assignment" />

    <HomeFeatureGrid SectionId="teacher-capabilities"
                     Title="Herramientas para tutorizacion eficiente"
                     Subtitle="Desde una sola pantalla puedes revisar candidatos, seguir el estado de tus propuestas y tomar decisiones con contexto.">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                <MudIcon Icon="@Icons.Material.Filled.EditNote" Color="Color.Primary" Size="Size.Large" Class="mb-3" />
                <MudText Typo="Typo.h6" Class="app-title-tight mb-2">Gestionar propuestas</MudText>
                <MudText Typo="Typo.body2" Class="home-card__description">Crea, ajusta y manten activas tus lineas de TFE con informacion clara para estudiantes.</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Info" Size="Size.Large" Class="mb-3" />
                <MudText Typo="Typo.h6" Class="app-title-tight mb-2">Evaluar candidatos</MudText>
                <MudText Typo="Typo.body2" Class="home-card__description">Analiza competencias y experiencia para seleccionar perfiles realmente alineados con tu propuesta.</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="home-card border-all rounded-xl h-100">
                <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Success" Size="Size.Large" Class="mb-3" />
                <MudText Typo="Typo.h6" Class="app-title-tight mb-2">Decidir con agilidad</MudText>
                <MudText Typo="Typo.body2" Class="home-card__description">Gestiona el estado de cada candidatura y reduce friccion en la coordinacion docente.</MudText>
            </MudPaper>
        </MudItem>
    </HomeFeatureGrid>

    <MudPaper Elevation="0" Class="home-highlight border-all rounded-xl">
        <MudText Typo="Typo.h6" Class="app-title-tight mb-2">Accion recomendada</MudText>
        <MudText Typo="Typo.body2" Class="home-highlight__description mb-4">
            Revisa el listado de candidatos pendientes en tus propuestas para avanzar decisiones esta semana.
        </MudText>
        <MudButton Href="/tfe/author" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Checklist" Class="rounded-lg font-weight-bold">
            Revisar mis TFE
        </MudButton>
    </MudPaper>
</div>
