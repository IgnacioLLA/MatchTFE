@using MudBlazor
@using TFELibrary.Shared

<MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-2 animate-fade-in">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudIcon Icon="@Icons.Material.Filled.School" Color="Color.Primary" />
        </CardHeaderAvatar>
        <CardHeaderContent> 
            <MudText Typo="Typo.h6" Class="font-weight-bold text-main">Académico y Habilidades</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6">
                <MudSelect T="string" @bind-Value="Model.AcademicYear" Label="CURSO ACADÉMICO" Variant="Variant.Outlined" Margin="Margin.Dense" Class="rounded-lg">
                    <MudSelectItem Value="@("3º Año")" />
                    <MudSelectItem Value="@("4º Año")" />
                    <MudSelectItem Value="@("Máster")" />
                </MudSelect>
            </MudItem>
        </MudGrid>

        @if (!Model.Skills.Any())
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Text" Class="mb-6 rounded-lg">
                Aún no has añadido ninguna habilidad técnica. ¡Los tutores las valoran mucho!
            </MudAlert>
        }

        <SkillSelector @bind-SelectedSkills="Model.Skills"
                       Title="HABILIDADES TÉCNICAS"
                       Placeholder="Buscar habilidades..." />
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public ProfileDto Model { get; set; } = default!;
}