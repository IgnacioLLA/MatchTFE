@using MudBlazor
@using TFELibrary.Shared

@inject IStringLocalizer<SharedResources> L

@* --- Tarjeta: Habilidades Técnicas --- *@
<MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-2 animate-fade-in">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Secondary" />
        </CardHeaderAvatar>
        <CardHeaderContent>
            <div class="d-flex align-center">
                <MudText Typo="Typo.h6" Class="font-weight-bold text-main">@L["Profile_TechnicalSkills"]</MudText>
                <MudTooltip Text="@L["Profile_SkillsTooltip"]" Placement="Placement.Right">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small"
                             Color="Color.Info" Class="ml-2" Style="cursor: help;" />
                </MudTooltip>
            </div>
            <MudText Typo="Typo.body2" Class="app-text-muted">
                @L["Profile_TechnicalSkillsSubtitle"]
            </MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <SkillSelector @bind-SelectedSkills="Model.Skills"
                       Placeholder="@L["Profile_TechnicalSkills"]" />
    </MudCardContent>
</MudCard>

@* --- Tarjeta: Información Académica --- *@
<MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-2 animate-fade-in">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudIcon Icon="@Icons.Material.Filled.School" Color="Color.Primary" />
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudText Typo="Typo.h6" Class="font-weight-bold text-main">@L["Profile_AcademicData"]</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Model.AcademicYear"
                              Label="@L["Profile_AcademicYear"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="rounded-lg"
                              Placeholder="@L["Profile_AcademicYearPlaceholder"]"
                              HelperText="@L["Profile_AcademicYearHelper"]" />
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public ProfileDto Model { get; set; } = default!;
}
