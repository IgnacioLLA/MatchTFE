@using System.Globalization
@using TFELibrary.Shared

@inject IStringLocalizer<SharedResources> L

@if (IsReadOnly)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-6 rounded-lg" Icon="@Icons.Material.Filled.Lock">
        @L["TfeForm_ReadOnlyNotice"]
    </MudAlert>
}

<MudGrid Spacing="4" Class="animate-fade-in">
    @* --- LEFT COLUMN --- *@
    <MudItem xs="12" md="7" lg="7">
        <MudPaper Elevation="0" Class="pa-8 rounded-xl border-all h-100">
            <div class="tfe-left-grid">
                <div class="d-flex align-center mb-2">
                    <MudText Typo="Typo.subtitle2" Class="app-subtitle mb-0">@L["TfeForm_TitleLabel"]</MudText>
                    <MudTooltip Text="@L["TfeForm_TitleTooltip"]" Placement="Placement.Right">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small"
                                 Color="Color.Info" Class="ml-2" Style="cursor: help;"
                                 aria-label="@L["TfeForm_TitleLabel"]" />
                    </MudTooltip>
                </div>
                <MudTextField @bind-Value="_title"
                              T="string"
                              Label="@L["TfeForm_TitleFieldLabel"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              HelperText="@L["TfeForm_TitleHelper"]"
                              Error="@(!string.IsNullOrWhiteSpace(_titleError))"
                              ErrorText="@_titleError"
                              ReadOnly="@IsReadOnly"
                              Class="mb-4 rounded-lg"
                              aria-required="true" />

                <div class="d-flex align-center mb-2">
                    <MudText Typo="Typo.subtitle2" Class="app-subtitle mb-0">@L["TfeForm_DescriptionLabel"]</MudText>
                    <MudTooltip Text="@L["TfeForm_DescriptionTooltip"]" Placement="Placement.Right">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small"
                                 Color="Color.Info" Class="ml-2" Style="cursor: help;"
                                 aria-label="@L["TfeForm_DescriptionLabel"]" />
                    </MudTooltip>
                </div>
                <div class="tfe-desc-wrap" style="@(IsReadOnly ? "pointer-events: none; opacity: 0.7;" : string.Empty)">
                    <textarea @bind="_description"
                              placeholder="@L["TfeForm_DescriptionFieldLabel"]"
                              class="tfe-native-textarea @(!string.IsNullOrWhiteSpace(_descriptionError) ? "tfe-native-error" : "")"
                              aria-required="true">
                    </textarea>
                    <MudText Typo="Typo.caption"
                             Class="@(!string.IsNullOrWhiteSpace(_descriptionError) ? "mud-error-text mt-1" : "app-text-muted mt-1")">
                        @(!string.IsNullOrWhiteSpace(_descriptionError) ? _descriptionError : L["TfeForm_DescriptionHelper"].Value)
                    </MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>

    @* --- RIGHT COLUMN  --- *@
    <MudItem xs="12" md="5" lg="5">
        <MudPaper Elevation="0" Class="pa-6 rounded-xl mb-6 border-all">
            <div class="d-flex align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-3 app-text-muted" />
                <MudText Typo="Typo.subtitle2" Class="app-subtitle mb-0">
                    @L["TfeForm_ExpirationLabel"]
                </MudText>
                <MudTooltip Text="@L["TfeForm_ExpirationTooltip"]" Placement="Placement.Right">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small"
                             Color="Color.Info" Class="ml-2" Style="cursor: help;"
                             aria-label="@L["TfeForm_ExpirationLabel"]" />
                </MudTooltip>
            </div>

            <div class="mb-2">
                <MudTextField T="string"
                              @bind-Value="_expirationDateText"
                              Label="@L["TfeForm_ExpirationFieldLabel"]"
                              InputType="InputType.Date"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              UserAttributes="_expirationDateInputAttributes"
                              Error="@(!string.IsNullOrWhiteSpace(_expirationDateError))"
                              ErrorText="@_expirationDateError"
                              ReadOnly="@IsReadOnly"
                              Class="rounded-lg" />
            </div>

            @if (IsEditMode)
            {
                <div class="d-flex align-center flex-wrap gap-2 mt-2">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@GetEditExpirationStatusColor()"
                             Variant="Variant.Filled"
                             Class="font-weight-bold px-3">
                        @GetEditExpirationStatusText()
                    </MudChip>

                        @if (!IsReadOnly && IsCurrentDateExpired())
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Autorenew"
                                       OnClick="RenewExpirationDateByThreeMonths"
                                       aria-label="@L["TfeForm_RenewBtn"]">
                                @L["TfeForm_RenewBtn"]
                            </MudButton>
                        }
                </div>
            }

            <MudText Typo="Typo.caption" Class="app-text-muted mt-2">
                @L["TfeForm_ExpirationCaption"]
            </MudText>

            <div class="d-flex align-center mt-6 mb-2">
                <MudText Typo="Typo.subtitle2" Class="app-subtitle mb-0">
                    @L["TfeForm_DurationLabel"]
                </MudText>
                <MudTooltip Text="@L["TfeForm_DurationTooltip"]" Placement="Placement.Right">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small"
                             Color="Color.Info" Class="ml-2" Style="cursor: help;"
                             aria-label="@L["TfeForm_DurationLabel"]" />
                </MudTooltip>
            </div>
            <MudSelect T="string"
                       @bind-Value="_estimatedDuration"
                       Label="@L["TfeForm_DurationFieldLabel"]"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       Placeholder="@L["TfeForm_DurationPlaceholder"]"
                       Margin="Margin.Dense"
                       Disabled="@IsReadOnly"
                       Error="@(!string.IsNullOrWhiteSpace(_estimatedDurationError))"
                       ErrorText="@_estimatedDurationError"
                       Class="rounded-lg">
                <MudSelectItem Value="@("3")">@L["TfeForm_Duration3M"]</MudSelectItem>
                <MudSelectItem Value="@("6")">@L["TfeForm_Duration6M"]</MudSelectItem>
                <MudSelectItem Value="@("9")">@L["TfeForm_Duration9M"]</MudSelectItem>
                <MudSelectItem Value="@("12")">@L["TfeForm_Duration12M"]</MudSelectItem>
            </MudSelect>
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-6 rounded-xl mb-6 border-all">
            <div style="@(IsReadOnly ? "pointer-events: none; opacity: 0.7;" : string.Empty)">
                <TagSelector @bind-SelectedTags="_selectedTopics"
                             Title="@L["TfeForm_TopicsLabel"]"
                             Icon="@Icons.Material.Filled.Category"
                             Placeholder="@L["TfeForm_TopicsPlaceholder"].Value"
                             TooltipText="@L["TfeForm_TopicsTooltip"]" />
            </div>
            <MudText Typo="Typo.caption" Class="app-text-muted mt-2">
                @L["TfeForm_TopicsCaption"]
            </MudText>
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-6 rounded-xl mb-6 border-all">
            <div style="@(IsReadOnly ? "pointer-events: none; opacity: 0.7;" : string.Empty)">
                <SkillSelector @bind-SelectedSkills="_requiredSkills"
                               Title="@L["TfeForm_SkillsLabel"]"
                               Icon="@Icons.Material.Filled.Build"
                               Placeholder="@L["TfeForm_SkillsPlaceholder"].Value"
                               TooltipText="@L["TfeForm_SkillsTooltip"]" />
            </div>
            <MudText Typo="Typo.caption" Class="app-text-muted mt-2">
                @L["TfeForm_SkillsCaption"]
            </MudText>
        </MudPaper>

        @if (!IsReadOnly)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       FullWidth="true"
                       EndIcon="@Icons.Material.Filled.Send"
                       Class="rounded-xl py-3 mt-2 btn-primary-shadow"
                       OnClick="HandleSubmitAsync">
                @(IsEditMode ? L["TfeForm_UpdateBtn"].Value : L["TfeForm_PublishBtn"].Value)
            </MudButton>
        }

        @if (!string.IsNullOrWhiteSpace(ServerError))
        {
            <MudAlert Severity="Severity.Error"
                      Variant="Variant.Filled"
                      Class="mt-4 rounded-lg"
                      role="alert"
                      aria-live="assertive">
                @ServerError
            </MudAlert>
        }
    </MudItem>
</MudGrid>

@code {
    [Parameter]
    public TfeDto? Tfe { get; set; }

    [Parameter]
    public EventCallback<TfeDto> OnValidSubmit { get; set; }

    [Parameter]
    public string? ServerError { get; set; }

    [Parameter]
    public EventCallback<string?> ServerErrorChanged { get; set; }

    [Parameter]
    public bool IsReadOnly { get; set; } = false;

    private bool IsEditMode => Tfe != null;

    private string _title = string.Empty;
    private string _description = string.Empty;
    private List<string> _selectedTopics = new();
    private List<SkillDto> _requiredSkills = new();
    private string _expirationDateText = DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd");
    private string _estimatedDuration = string.Empty;
    private string? _titleError;
    private string? _descriptionError;
    private string? _expirationDateError;
    private string? _estimatedDurationError;

    private static string MinimumExpirationDateText => TfeDateRules.ToInputDateValue(TfeDateRules.MinimumExpirationDate);

    private Dictionary<string, object> _expirationDateInputAttributes => new()
    {
        ["min"] = MinimumExpirationDateText
    };

    protected override void OnParametersSet()
    {
        if (IsEditMode && string.IsNullOrEmpty(_title))
        {
            _title = Tfe!.Title ?? string.Empty;
            _description = Tfe.Description ?? string.Empty;

            _selectedTopics = Tfe.Topics?.Select(t => t.Name).ToList() ?? new();
            _requiredSkills = Tfe.RequiredSkills?.ToList() ?? new();

            _expirationDateText = Tfe.ExpirationDate != default
                ? Tfe.ExpirationDate.ToString("yyyy-MM-dd")
                : string.Empty;

            if (Tfe.EstimatedDelivery != default)
            {
                var months = ((Tfe.EstimatedDelivery.Year - DateTime.Today.Year) * 12) +
                               Tfe.EstimatedDelivery.Month - DateTime.Today.Month;
                _estimatedDuration = $"{Math.Max(3, months)}";
            }
        }
    }

    private async Task HandleSubmitAsync()
    {
        await ServerErrorChanged.InvokeAsync(null);

        if (!CheckForm()) return;

        DateOnly.TryParseExact(_expirationDateText, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var expirationDate);

        var resultTfe = new TfeDto
        {
            Title = _title.Trim(),
            Description = _description.Trim(),
            Topics = _selectedTopics.Select(topic => new TagDto { Name = topic }).ToList(),
            RequiredSkills = _requiredSkills.ToList(),
            EstimatedDelivery = DateTime.Today.AddMonths(ParseEstimatedMonths(_estimatedDuration)),
            ExpirationDate = expirationDate == default ? DateTime.Today.AddMonths(1) : expirationDate.ToDateTime(TimeOnly.MinValue)
        };

        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync(resultTfe);
        }
    }

    private void RenewExpirationDateByThreeMonths()
    {
        _expirationDateText = TfeDateRules.ToInputDateValue(
            DateOnly.FromDateTime(DateTime.Today.AddMonths(3)));
        _expirationDateError = null;
    }

    private static int ParseEstimatedMonths(string estimatedDuration)
    {
        if (int.TryParse(estimatedDuration, out int result))
            return result;
        return 12;
    }

    private bool CheckForm()
    {
        _titleError = null;
        _descriptionError = null;
        _expirationDateError = null;
        _estimatedDurationError = null;

        if (string.IsNullOrWhiteSpace(_title) || string.IsNullOrWhiteSpace(_description))
        {
            if (string.IsNullOrWhiteSpace(_title))
            {
                _titleError = L["TfeForm_TitleError"].Value;
            }

            if (string.IsNullOrWhiteSpace(_description))
            {
                _descriptionError = L["TfeForm_DescriptionError"].Value;
            }

            return false;
        }

        if (string.IsNullOrWhiteSpace(_expirationDateText) ||
            !DateOnly.TryParseExact(_expirationDateText, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var expirationDate))
        {
            _expirationDateError = L["TfeForm_ExpirationError"].Value;
            return false;
        }

        if (!IsExpirationDateAllowed(expirationDate))
        {
            _expirationDateError = L["TfeForm_ExpirationMinError", TfeDateRules.MinimumExpirationDate.ToString("dd/MM/yyyy", CultureInfo.CurrentCulture)].Value;
            return false;
        }

        if (string.IsNullOrWhiteSpace(_estimatedDuration))
        {
            _estimatedDurationError = L["TfeForm_DurationError"].Value;
            return false;
        }

        return true;
    }

    private bool IsExpirationDateAllowed(DateOnly selectedDate)
    {
        if (!IsEditMode || Tfe == null || Tfe.ExpirationDate == default)
        {
            return TfeDateRules.IsValidExpirationDate(selectedDate);
        }

        var currentExpirationDate = DateOnly.FromDateTime(Tfe.ExpirationDate);
        if (selectedDate == currentExpirationDate)
        {
            return true;
        }

        return TfeDateRules.IsValidExpirationDate(selectedDate);
    }

    private bool IsCurrentDateExpired()
    {
        if (!DateOnly.TryParseExact(_expirationDateText, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var date))
            return true;
        return date.ToDateTime(TimeOnly.MinValue).Date < DateTime.Today;
    }

    private Color GetEditExpirationStatusColor()
    {
        if (!IsEditMode) return Color.Success;
        return IsCurrentDateExpired() ? Color.Error : Color.Success;
    }

    private string GetEditExpirationStatusText()
    {
        if (!IsEditMode) return string.Empty;
        return IsCurrentDateExpired() ? L["TfeForm_ExpiredStatus"].Value : L["TfeForm_OpenStatus"].Value;
    }
}
