@inherits LayoutComponentBase
@using TFELibrary.Shared
@using MatchTFE.Client.Themes

@inject IHttpClientFactory ClientFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L
@inject IJSRuntime JS

<MudThemeProvider Theme="MatchTheme.DefaultTheme" @bind-IsDarkMode="_isDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="@DrawerVariant.Responsive">
        <div class="pa-4 mt-2">
            <MudText Typo="Typo.overline" Class="mud-text-secondary font-weight-bold">
                @L["Nav_MenuTitle"]
            </MudText>
        </div>
        <NavMenu Profile="_globalProfile" />
    </MudDrawer>

    <MudAppBar Elevation="0">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="DrawerToggle" />

        <MudLink Href="/" Underline="Underline.None" Color="Color.Inherit" Class="d-flex align-center">
            <MudText Typo="Typo.h6" Class="ml-3 font-weight-extrabold">
                MATCH-TFE
            </MudText>
        </MudLink>

        <MudSpacer />

        <MudToggleIconButton @bind-Toggled="_isDarkMode"
                             Icon="@Icons.Material.Filled.WbSunny"
                             Color="Color.Inherit"
                             ToggledIcon="@Icons.Material.Filled.DarkMode"
                             ToggledColor="Color.Inherit" />

        <MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" Class="mx-2"
                 Dense="true">
            <MudMenuItem OnClick="@(() => SetCultureAsync("es-ES"))">
                <div class="d-flex align-center gap-2">
                    @if (CurrentCulture.StartsWith("es"))
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                    }
                    🇪🇸 @L["Lang_Spanish"]
                </div>
            </MudMenuItem>
            <MudMenuItem OnClick="@(() => SetCultureAsync("en"))">
                <div class="d-flex align-center gap-2">
                    @if (CurrentCulture.StartsWith("en"))
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                    }
                    🇬🇧 @L["Lang_English"]
                </div>
            </MudMenuItem>
        </MudMenu>

        <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="px-2" Href="/profile">
            @if (_isLoading)
            {
                <MudProgressCircular Color="Color.Inherit" Size="Size.Small" Indeterminate="true" />
            }
            else if (_globalProfile != null)
            {
                <MudAvatar Variant="Variant.Filled" Size="Size.Medium" Class="mr-sm-3" Color="Color.Primary">
                    @(_globalProfile.FirstName.FirstOrDefault())@(_globalProfile.LastName.FirstOrDefault())
                </MudAvatar>
                <div class="d-none d-sm-flex flex-column align-start">
                    <MudText Typo="Typo.body2" Color="Color.Inherit" Class="font-weight-bold">
                        @_globalProfile.FirstName @_globalProfile.LastName
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Inherit" Class="app-caption-uppercase">
                        @GetRoleCaption(_globalProfile.Role)
                    </MudText>
                </div>
            }
        </MudButton>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 px-4 px-sm-12">
            @if (_isLoading)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
            }
            else if (_globalProfile == null && !_isPublicRoute)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
            }
            else if (_globalProfile == null)
            {
                @Body
            }
            else
            {
                <CascadingValue Value="@_globalProfile">
                    @Body
                </CascadingValue>
            }
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private ProfileDto? _globalProfile;
    private bool _isLoading = true;
    private bool _isPublicRoute;

    private string CurrentCulture => System.Globalization.CultureInfo.CurrentCulture.Name;

    private async Task SetCultureAsync(string culture)
    {
        await JS.InvokeVoidAsync("blazorCulture.set", culture);
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    protected override async Task OnInitializedAsync()
    {
        var currentPath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var normalized = string.IsNullOrWhiteSpace(currentPath)
            ? "/"
            : $"/{currentPath.TrimStart('/')}";

        _isPublicRoute = IsPublicRoute(normalized);

        if (_isPublicRoute)
        {
            _isLoading = false;
            return;
        }

        await CargarPerfilGlobalAsync();

        if (_globalProfile == null && OperatingSystem.IsBrowser())
        {
            Navigation.NavigateTo("/login", replace: true);
        }
    }

    private async Task CargarPerfilGlobalAsync()
    {
        try
        {
            var http = ClientFactory.CreateClient("GatewayAPI");
            var result = await http.GetFromJsonAsync<ProfileResponse>("api/user/profile");
            _globalProfile = result?.Profile;
        }
        catch (Exception)
        {
            Snackbar.Add(L["Layout_ProfileLoadError"], Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetRoleCaption(RoleType role) => role switch
    {
        RoleType.Student => L["Role_Student"].Value.ToUpperInvariant(),
        RoleType.Teacher => L["Role_Teacher"].Value.ToUpperInvariant(),
        RoleType.Admin => L["Role_Admin"].Value.ToUpperInvariant(),
        _ => L["Role_User"].Value.ToUpperInvariant()
    };

    private static bool IsPublicRoute(string normalizedPath)
        => normalizedPath.Equals("/login", StringComparison.OrdinalIgnoreCase)
           || normalizedPath.Equals("/register", StringComparison.OrdinalIgnoreCase)
           || normalizedPath.Equals("/not-found", StringComparison.OrdinalIgnoreCase);
}
