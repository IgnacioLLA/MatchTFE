<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Inicio</MudNavLink>
    @if (IsStudentOrTeacher)
    {
        <MudNavLink Href="/tfe/feed" Icon="@Icons.Material.Filled.Explore" IconColor="Color.Primary">Descubrir</MudNavLink>
        <MudNavLink Href="/match" Icon="@Icons.Material.Filled.Layers">Mis Matches</MudNavLink>
        <MudNavLink Href="/tfe/create" Icon="@Icons.Material.Filled.AddCircle">Crear Propuesta</MudNavLink>
        <MudNavLink Href="/tfe/author" Icon="@Icons.Material.Filled.AddCircle">Ver mis propuestas</MudNavLink>
    }
    @if (Profile?.Role == RoleType.Admin)
    {
        <MudNavLink Href="/admin" Icon="@Icons.Material.Filled.AdminPanelSettings">Administración</MudNavLink>
    }
    <MudNavLink Href="/profile" Icon="@Icons.Material.Filled.Person">Mi Perfil</MudNavLink>
</MudNavMenu>

@code {
    [Parameter]
    public ProfileDto? Profile { get; set; }

    private bool IsStudentOrTeacher => Profile?.Role is RoleType.Student or RoleType.Teacher;
}