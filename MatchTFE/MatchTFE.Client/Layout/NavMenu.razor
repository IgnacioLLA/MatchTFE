@inject IStringLocalizer<SharedResources> L

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">@L["Nav_Home"]</MudNavLink>
    @if (IsStudentOrTeacher)
    {
        <MudNavLink Href="/tfe/feed" Icon="@Icons.Material.Filled.Explore" IconColor="Color.Primary">@L["Nav_Discover"]</MudNavLink>
        <MudNavLink Href="/match" Icon="@Icons.Material.Filled.Layers">@L["Nav_MyMatches"]</MudNavLink>
        <MudNavLink Href="/tfe/create" Icon="@Icons.Material.Filled.AddCircle">@L["Nav_CreateProposal"]</MudNavLink>
        <MudNavLink Href="/tfe/author" Icon="@Icons.Material.Filled.AddCircle">@L["Nav_MyProposals"]</MudNavLink>
    }
    @if (Profile?.Role == RoleType.Admin)
    {
        <MudNavLink Href="/admin" Icon="@Icons.Material.Filled.AdminPanelSettings">@L["Nav_Admin"]</MudNavLink>
    }
    <MudNavLink Href="/profile" Icon="@Icons.Material.Filled.Person">@L["Nav_Profile"]</MudNavLink>
</MudNavMenu>

@code {
    [Parameter]
    public ProfileDto? Profile { get; set; }

    private bool IsStudentOrTeacher => Profile?.Role is RoleType.Student or RoleType.Teacher;
}
