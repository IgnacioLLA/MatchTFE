@page "/profile/{UserId}"
@using TFELibrary.Shared
@using System.Net.Http.Json

@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<div class="animate-fade-in max-w-5xl mx-auto pb-10">

    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               Color="Color.Default"
               Class="mb-6 font-weight-bold"
               OnClick="GoBack">
        Volver
    </MudButton>

    @if (_isLoading)
    {
        <div class="d-flex justify-center align-center mt-15">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (_profile == null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4 rounded-lg">
            No se ha podido cargar el perfil del usuario.
        </MudAlert>
    }
    else
    {
        <ProfileCard Profile="_profile" />

        @if (AllowActions && TfeId.HasValue)
        {
            <MudPaper Elevation="0" Class="pa-4 rounded-xl app-actions-bar border-all mt-6">
                <div class="d-flex flex-column flex-sm-row align-center justify-center gap-3">
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Large"
                               OnClick="@(() => HandleDecision(false))"
                               Class="rounded-lg px-8 py-3 font-weight-bold w-100 w-sm-auto" StartIcon="@Icons.Material.Filled.Close">
                        DESCARTAR
                    </MudButton>

                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large"
                               OnClick="@(() => HandleDecision(true))"
                               Class="rounded-lg px-8 py-3 font-weight-bold w-100 w-sm-auto" StartIcon="@Icons.Material.Filled.Favorite">
                        ME INTERESA
                    </MudButton>
                </div>
            </MudPaper>
        }
    }
</div>

@code {
    [Parameter]
    public string UserId { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "tfeId")]
    public int? TfeId { get; set; }

    [SupplyParameterFromQuery(Name = "allowActions")]
    public bool AllowActions { get; set; }

    private ProfileDto? _profile;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserProfileAsync();
    }

    private async Task LoadUserProfileAsync()
    {
        _isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");

            var response = await client.GetFromJsonAsync<ProfileResponse>($"api/user/profile/{UserId}");

            if (response != null && response.Profile != null)
            {
                _profile = response.Profile;
            }
            else
            {
                Snackbar.Add("El perfil devuelto está vacío.", Severity.Warning);
            }
        }
        catch (HttpRequestException)
        {
            Snackbar.Add("User not found.", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Error.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task GoBack()
    {
        await JSRuntime.InvokeVoidAsync("history.back");
    }

    private async Task HandleDecision(bool isInterested)
    {
        if (_profile == null || !TfeId.HasValue)
        {
            Snackbar.Add("No se puede decidir sobre este candidato sin contexto de TFE.", Severity.Warning);
            return;
        }

        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            var response = await client.PutAsJsonAsync("api/match/proposal/tfe/decision", new TfeCandidateDecisionRequest
            {
                TfeId = TfeId.Value,
                CandidateId = UserId,
                Status = isInterested ? ProposalStatus.Accepted : ProposalStatus.Rejected
            });

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(isInterested
                    ? $"Has aceptado a {_profile.FirstName} para tu propuesta."
                    : $"Has descartado a {_profile.FirstName}.",
                    isInterested ? Severity.Success : Severity.Normal);

                await GoBack();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                Snackbar.Add("Esta propuesta ya fue resuelta.", Severity.Warning);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                Snackbar.Add("No tienes permisos para decidir sobre este candidato.", Severity.Error);
            }
            else
            {
                Snackbar.Add("Hubo un problema al registrar la decisión.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Error de conexión al servidor.", Severity.Error);
        }
    }
}