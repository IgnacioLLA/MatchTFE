@page "/tfe/{TfeId:int}/candidates"
@using TFELibrary.Shared
@using System.Net.Http.Json

@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L

<div class="animate-fade-in max-w-5xl mx-auto pb-10">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               Color="Color.Default"
               Class="mb-4 font-weight-bold"
               OnClick="@(() => Navigation.NavigateTo("/tfe/author"))">
        @L["Candidates_BackBtn"]
    </MudButton>

    @if (_isLoading)
    {
        <div class="d-flex justify-center align-center mt-15">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (_tfe == null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4 rounded-lg">
            @L["Candidates_NotFound"]
        </MudAlert>
    }
    else
    {
        <TfeSummary Tfe="_tfe" CandidateCount="_candidates.Count" />

        <div class="mt-8">
            <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">
                @L["Candidates_Title"]
            </MudText>

            @if (_tfe.Status == TfeStatus.Completed)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4 rounded-lg">
                    @L["Candidates_CompletedNotice"]
                </MudAlert>
            }

            @if (!_candidates.Any())
            {
                <MudPaper Elevation="0" Class="pa-8 text-center rounded-xl border-all mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Class="icon-huge mb-4" />
                    <MudText Typo="Typo.h6" Color="Color.Inherit">@L["Candidates_NoneTitle"]</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Inherit">@L["Candidates_NoneBody"]</MudText>
                </MudPaper>
            }
            else
            {
                @foreach (var candidate in _candidates)
                {
                    <CandidateListItem Candidate="candidate"
                                       IsActionsDisabled="@(_tfe.Status == TfeStatus.Completed)"
                                       OnViewProfile="HandleViewProfile"
                                       OnReject="HandleRejectAsync"
                                       OnAccept="HandleAcceptAsync" />
                }
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public int TfeId { get; set; }

    private bool _isLoading = true;
    private TfeDto? _tfe;
    private List<TfeCandidateDto> _candidates = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            _tfe = await client.GetFromJsonAsync<TfeDto>($"api/match/tfe/{TfeId}");

            var response = await client.GetFromJsonAsync<ProfileByTfeInterestResponse>($"api/user/tfe/{TfeId}/candidates");

            if (response != null && response.Interested != null)
            {
                _candidates = response.Interested
                    .OrderBy(c => GetStatusSortOrder(c.Status))
                    .ToList();
            }
        }
        catch { }
        finally
        {
            _isLoading = false;
        }
    }

    private static int GetStatusSortOrder(ProposalStatus status) => status switch
    {
        ProposalStatus.Pending  => 0,
        ProposalStatus.Accepted => 1,
        ProposalStatus.Rejected => 2,
        _                       => 3
    };

    private void HandleViewProfile(TfeCandidateDto candidate)
    {
        Navigation.NavigateTo($"/profile/{candidate.Profile.Id}?tfeId={TfeId}&allowActions={candidate.CanDecide.ToString().ToLowerInvariant()}");
    }

    private async Task HandleRejectAsync(TfeCandidateDto candidate)
    {
        await DecideAsync(candidate, ProposalStatus.Rejected);
    }

    private async Task HandleAcceptAsync(TfeCandidateDto candidate)
    {
        await DecideAsync(candidate, ProposalStatus.Accepted);
    }

    private async Task DecideAsync(TfeCandidateDto candidate, ProposalStatus status)
    {
        if (!candidate.CanDecide)
            return;

        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            var response = await client.PutAsJsonAsync("api/match/proposal/tfe/decision", new TfeCandidateDecisionRequest
            {
                TfeId = TfeId,
                CandidateId = candidate.Profile.Id,
                Status = status
            });

            if (response.IsSuccessStatusCode)
            {
                candidate.Status = status;
                _candidates = [.. _candidates.OrderBy(c => GetStatusSortOrder(c.Status))];
                Snackbar.Add(status == ProposalStatus.Accepted
                    ? L["Candidates_AcceptedMsg", candidate.Profile.FirstName].Value
                    : L["Candidates_RejectedMsg", candidate.Profile.FirstName].Value,
                    status == ProposalStatus.Accepted ? Severity.Success : Severity.Normal);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                Snackbar.Add(L["Candidates_AlreadyResolved"].Value, Severity.Warning);
                await LoadDataAsync();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                Snackbar.Add(L["Candidates_NoPermission"].Value, Severity.Error);
            }
            else
            {
                Snackbar.Add(L["Candidates_DecisionError"].Value, Severity.Error);
            }
        }
        catch { }
    }
}
