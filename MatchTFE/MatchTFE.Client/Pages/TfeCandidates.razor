@page "/tfe/{TfeId:int}/candidates"
@using TFELibrary.Shared
@using System.Net.Http.Json

@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<div class="animate-fade-in max-w-5xl mx-auto pb-10">
    
    @* BACK *@
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" 
               Color="Color.Default" 
               Class="mb-4 font-weight-bold" 
               OnClick="@(() => Navigation.NavigateTo("/tfe/author"))">
        Volver a Mis Publicaciones
    </MudButton>

    @if (_isLoading)
    {
        <div class="d-flex justify-center align-center mt-15">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (_tfe == null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4 rounded-lg">
            No se ha podido encontrar la propuesta o no tienes permisos para verla.
        </MudAlert>
    }
    else
    {
        @* HEADER *@
        <TfeSummary Tfe="_tfe" CandidateCount="_candidates.Count" />

        @* INTERESTED LIST *@
        <div class="mt-8">
            <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">
                Candidatos Postulados
            </MudText>

            @if (!_candidates.Any())
            {
                <MudPaper Elevation="0" Class="pa-8 text-center rounded-xl border-all app-text-muted" Style="background-color: var(--app-primary-light);">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Class="icon-huge mb-4" />
                    <MudText Typo="Typo.h6">Aún no hay candidatos</MudText>
                    <MudText Typo="Typo.body2">Los estudiantes interesados aparecerán aquí.</MudText>
                </MudPaper>
            }
            else
            {
                @foreach (var candidate in _candidates)
                {
                    <CandidateListItem Candidate="candidate" 
                                       OnViewProfile="HandleViewProfile"
                                       OnReject="HandleRejectAsync"
                                       OnAccept="HandleAcceptAsync" />
                }
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public int TfeId { get; set; }

    private bool _isLoading = true;
    private TfeDto? _tfe;
    private List<ProfileDto> _candidates = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            _tfe = await client.GetFromJsonAsync<TfeDto>($"api/match/tfe/{TfeId}");

            var response = await client.GetFromJsonAsync<ProfileByTfeInterestResponse>($"api/user/tfe/{TfeId}/candidates");

            if (response != null && response.Interested != null)
            {
                _candidates = response.Interested;
            }
        }
        catch(Exception e)
        {
            Snackbar.Add("Hubo un error: " + e.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void HandleViewProfile(ProfileDto profile)
    {
        Navigation.NavigateTo($"/profile/{profile.Id}");
    }

    private async Task HandleRejectAsync(ProfileDto profile)
    {
        
    }

    private async Task HandleAcceptAsync(ProfileDto profile)
    {
        
    }
}