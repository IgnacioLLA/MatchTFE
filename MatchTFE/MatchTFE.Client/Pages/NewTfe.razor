@page "/tfe/create"
@using TFELibrary.Shared
@using System.Net.Http.Json

@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory

<div class="mb-8 animate-fade-in">
    <MudText Typo="Typo.h4" Class="app-title-tight text-main mb-2">
        Nueva Propuesta de TFE
    </MudText>
    <MudText Typo="Typo.body1" Class="app-text-reading">
        Define los detalles académicos para atraer a los estudiantes con mejor perfil para tu investigación.
    </MudText>
</div>

<TfeForm OnValidSubmit="CreateProposalAsync"
         ServerError="@_serverError"
         ServerErrorChanged="@(v => { _serverError = v; StateHasChanged(); })" />

@code {
    private string? _serverError;

    private async Task CreateProposalAsync(TfeDto newTfe)
    {
        var request = new TfeCreationRequest { Tfe = newTfe };

        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");

            var response = await client.PostAsJsonAsync("api/match/tfe", request);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Propuesta publicada correctamente.", Severity.Success);
                Navigation.NavigateTo("/tfe/author");
                return;
            }

            var error = await response.Content.ReadAsStringAsync();
            _serverError = $"No se pudo crear ({(int)response.StatusCode}): {error}";
        }
        catch
        {
            _serverError = "Error al conectar con el servidor. Inténtalo de nuevo.";
        }
    }
}
