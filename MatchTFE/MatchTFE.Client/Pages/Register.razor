@page "/register"
@using TFELibrary.Shared

@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> L

@layout AuthLayout

<MudCard Class="auth-card register-card">
    <MudCardContent Class="auth-card-content">
        <MudText Typo="Typo.h5" Class="auth-title">@L["Register_Title"]</MudText>
        <MudText Typo="Typo.body2" Class="auth-subtitle">@L["Register_Subtitle"]</MudText>

        <div class="form-row-2">
            <MudTextField @bind-Value="_model.FirstName"
                          Label="@L["Register_FirstName"]"
                          Placeholder="@L["Register_FirstNamePlaceholder"]"
                          Variant="Variant.Outlined"
                          AutoComplete="given-name"
                          Class="auth-input"
                          Error="@(_firstNameError != null)"
                          ErrorText="@_firstNameError" />

            <MudTextField @bind-Value="_model.LastName"
                          Label="@L["Register_LastName"]"
                          Placeholder="@L["Register_LastNamePlaceholder"]"
                          Variant="Variant.Outlined"
                          AutoComplete="family-name"
                          Class="auth-input"
                          Error="@(_lastNameError != null)"
                          ErrorText="@_lastNameError" />
        </div>

        <MudTextField @bind-Value="_model.Email"
                      Label="@L["Register_Email"]"
                      Placeholder="@L["Register_EmailPlaceholder"]"
                      Variant="Variant.Outlined"
                      InputType="InputType.Email"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.Email"
                      AutoComplete="email"
                      Class="auth-input"
                      Error="@(_emailError != null)"
                      ErrorText="@_emailError" />

        <MudTextField @bind-Value="_confirmEmail"
                      Label="@L["Register_ConfirmEmail"]"
                      Placeholder="@L["Register_ConfirmEmailPlaceholder"]"
                      Variant="Variant.Outlined"
                      InputType="InputType.Email"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.MarkEmailRead"
                      AutoComplete="email"
                      Class="auth-input"
                      Error="@(_confirmEmailError != null)"
                      ErrorText="@_confirmEmailError" />

        <MudTextField @bind-Value="_model.Password"
                      Label="@L["Register_Password"]"
                      Placeholder="@L["Register_PasswordPlaceholder"]"
                      Variant="Variant.Outlined"
                      InputType="@_passwordInput"
                      Adornment="Adornment.End"
                      AdornmentIcon="@_passwordIcon"
                      OnAdornmentClick="TogglePasswordVisibility"
                      AutoComplete="new-password"
                      Class="auth-input register-password-input"
                      Error="@(_passwordError != null)"
                      ErrorText="@_passwordError" />

        <MudTextField @bind-Value="_confirmPassword"
                      Label="@L["Register_ConfirmPassword"]"
                      Placeholder="@L["Register_ConfirmPasswordPlaceholder"]"
                      Variant="Variant.Outlined"
                      InputType="@_confirmPasswordInput"
                      Adornment="Adornment.End"
                      AdornmentIcon="@_confirmPasswordIcon"
                      OnAdornmentClick="ToggleConfirmPasswordVisibility"
                      AutoComplete="new-password"
                      Class="auth-input register-password-input"
                      Error="@(_confirmPasswordError != null)"
                      ErrorText="@_confirmPasswordError" />

        <MudText Typo="Typo.caption" Class="password-hint">
            @L["Register_PasswordHint"]
        </MudText>

        <MudButton ButtonType="ButtonType.Button"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Disabled="@_isLoading"
                   OnClick="HandleRegisterAsync"
                   Class="auth-button">
            @if (_isLoading)
            {
                <MudProgressCircular Indeterminate="true" Class="loading-spinner" />
                <span class="loading-text">@L["Register_Loading"]</span>
            }
            else
            {
                <span class="button-content">@L["Register_Submit"] <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="btn-icon" /></span>
            }
        </MudButton>

        <div class="auth-bottom-section">
            <MudText Typo="Typo.body2" Class="auth-bottom-text">@L["Register_AlreadyHaveAccount"]</MudText>
            <MudLink Href="/login" Typo="Typo.body2" Underline="Underline.Hover" Class="auth-bottom-link">@L["Register_SignIn"]</MudLink>
        </div>
    </MudCardContent>
</MudCard>

@code {
    private RegisterRequestDto _model = new();
    private string _confirmEmail = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _isLoading = false;

    private string? _firstNameError;
    private string? _lastNameError;
    private string? _emailError;
    private string? _confirmEmailError;
    private string? _passwordError;
    private string? _confirmPasswordError;

    private InputType _passwordInput = InputType.Password;
    private string _passwordIcon = Icons.Material.Outlined.VisibilityOff;

    private InputType _confirmPasswordInput = InputType.Password;
    private string _confirmPasswordIcon = Icons.Material.Outlined.VisibilityOff;

    private void TogglePasswordVisibility()
    {
        if (_passwordInput == InputType.Password)
        {
            _passwordInput = InputType.Text;
            _passwordIcon = Icons.Material.Outlined.Visibility;
        }
        else
        {
            _passwordInput = InputType.Password;
            _passwordIcon = Icons.Material.Outlined.VisibilityOff;
        }
    }

    private void ToggleConfirmPasswordVisibility()
    {
        if (_confirmPasswordInput == InputType.Password)
        {
            _confirmPasswordInput = InputType.Text;
            _confirmPasswordIcon = Icons.Material.Outlined.Visibility;
        }
        else
        {
            _confirmPasswordInput = InputType.Password;
            _confirmPasswordIcon = Icons.Material.Outlined.VisibilityOff;
        }
    }

    private bool CheckForm()
    {
        _firstNameError = null;
        _lastNameError = null;
        _emailError = null;
        _confirmEmailError = null;
        _passwordError = null;
        _confirmPasswordError = null;

        if (string.IsNullOrWhiteSpace(_model.FirstName))
            _firstNameError = L["Register_FirstNameRequired"].Value;

        if (string.IsNullOrWhiteSpace(_model.LastName))
            _lastNameError = L["Register_LastNameRequired"].Value;

        if (string.IsNullOrWhiteSpace(_model.Email))
            _emailError = L["Register_EmailRequired"].Value;
        else if (!IsValidEmail(_model.Email))
            _emailError = L["Register_EmailInvalid"].Value;

        if (string.IsNullOrWhiteSpace(_confirmEmail))
            _confirmEmailError = L["Register_ConfirmEmailRequired"].Value;
        else if (_model.Email != _confirmEmail)
            _confirmEmailError = L["Register_EmailMismatch"].Value;

        if (string.IsNullOrWhiteSpace(_model.Password))
            _passwordError = L["Register_PasswordRequired"].Value;
        else if (_model.Password.Length < 6)
            _passwordError = L["Register_PasswordTooShort"].Value;
        else if (!IsPasswordComplex(_model.Password))
            _passwordError = L["Register_PasswordComplexityError"].Value;

        if (string.IsNullOrWhiteSpace(_confirmPassword))
            _confirmPasswordError = L["Register_ConfirmPasswordRequired"].Value;
        else if (_model.Password != _confirmPassword)
            _confirmPasswordError = L["Register_PasswordMismatch"].Value;

        return _firstNameError == null && _lastNameError == null &&
               _emailError == null && _confirmEmailError == null &&
               _passwordError == null && _confirmPasswordError == null;
    }

    private static bool IsPasswordComplex(string password) =>
        password.Length >= 6 &&
        password.Any(char.IsUpper) &&
        password.Any(char.IsLower) &&
        password.Any(char.IsDigit) &&
        password.Any(c => !char.IsLetterOrDigit(c));

    private static bool IsValidEmail(string email)
    {
        var at = email.IndexOf('@');
        if (at < 1 || email.IndexOf('@', at + 1) >= 0) return false;
        var domain = email[(at + 1)..];
        var dot = domain.LastIndexOf('.');
        return dot > 0 && dot < domain.Length - 1;
    }

    private async Task HandleRegisterAsync()
    {
        if (!CheckForm()) return;

        _isLoading = true;
        try
        {
            var http = ClientFactory.CreateClient("GatewayAPI");
            var response = await http.PostAsJsonAsync("api/auth/register", _model);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<RegisterResponseDto>();

                if (result != null && result.Error.IsSuccess)
                {
                    Snackbar.Add(L["Register_SuccessMessage"].Value, Severity.Success);
                    Navigation.NavigateTo("/login");
                }
                else
                {
                    var warnMsg = result?.Error?.ErrorCode switch
                    {
                        "DuplicateEmail" => L["Register_EmailAlreadyTaken"].Value,
                        _                => L["Register_DefaultError"].Value
                    };
                    Snackbar.Add(warnMsg, Severity.Warning);
                }
            }
            else
            {
                var errorResult = await response.Content.ReadFromJsonAsync<RegisterResponseDto>();
                var errMsg = errorResult?.Error?.ErrorCode switch
                {
                    "DuplicateEmail" => L["Register_EmailAlreadyTaken"].Value,
                    _                => L["Register_ProcessError"].Value
                };
                Snackbar.Add(errMsg, Severity.Error);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }
}
