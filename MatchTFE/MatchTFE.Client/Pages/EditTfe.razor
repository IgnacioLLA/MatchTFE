@page "/tfe/edit/{Id:int}"
@using TFELibrary.Shared
@using System.Net.Http.Json
@using MudBlazor

@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject IDialogService DialogService
@inject IStringLocalizer<SharedResources> L

<div class="mb-8 animate-fade-in">
    <MudText Typo="Typo.h4" Class="app-title-tight text-main mb-2">
        @L["TfeForm_EditTitle"]
    </MudText>
    <MudText Typo="Typo.body1" Class="app-text-reading">
        @L["TfeForm_EditSubtitle"]
    </MudText>
</div>

@if (_isLoading)
{
    <div class="d-flex justify-center mt-10">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else if (_tfeToEdit != null)
{
    @if (_tfeToEdit.Status == TfeStatus.Open)
    {
        <div class="d-flex gap-3 mb-6 flex-wrap">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       Class="rounded-lg font-weight-bold"
                       OnClick="ShowFinalizeModalAsync">
                @L["EditTfe_FinalizeBtn"]
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Cancel"
                       Class="rounded-lg font-weight-bold"
                       OnClick="ShowCancelModalAsync">
                @L["EditTfe_CancelTfeBtn"]
            </MudButton>
        </div>
    }

    <TfeForm Tfe="@_tfeToEdit"
             IsReadOnly="@(_tfeToEdit.Status == TfeStatus.Completed)"
             OnValidSubmit="UpdateProposalAsync"
             ServerError="@_serverError"
             ServerErrorChanged="@(v => { _serverError = v; StateHasChanged(); })" />
}

@code {
    [Parameter]
    public int Id { get; set; }

    private TfeDto? _tfeToEdit;
    private bool _isLoading = true;
    private string? _serverError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            _tfeToEdit = await client.GetFromJsonAsync<TfeDto>($"api/match/tfe/{Id}");
        }
        catch { }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task UpdateProposalAsync(TfeDto updatedTfe)
    {
        updatedTfe.Id = Id;

        var request = new TfeUpdateRequest { Tfe = updatedTfe };

        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            var response = await client.PutAsJsonAsync($"api/match/tfe/{Id}", request);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(L["TfeForm_UpdatedSuccess"].Value, Severity.Success);
                Navigation.NavigateTo("/tfe/author");
                return;
            }

            _serverError = L["TfeForm_UpdateError"].Value;
        }
        catch
        {
            _serverError = L["TfeForm_ConnectionError"].Value;
        }
    }

    private async Task ShowFinalizeModalAsync()
    {
        var parameters = new DialogParameters
        {
            ["Title"] = L["EditTfe_FinalizeModal_Title"].Value,
            ["Body"] = L["EditTfe_FinalizeModal_Body"].Value,
            ["ConfirmText"] = L["EditTfe_FinalizeModal_Confirm"].Value,
            ["CancelText"] = L["EditTfe_ModalCancel"].Value,
            ["ConfirmColor"] = Color.Success
        };

        var dialog = await DialogService.ShowAsync<TfeStatusConfirmDialog>(string.Empty, parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
            await ChangeStatusAsync(TfeStatus.Completed, L["EditTfe_FinalizeSuccess"].Value);
    }

    private async Task ShowCancelModalAsync()
    {
        var parameters = new DialogParameters
        {
            ["Title"] = L["EditTfe_CancelModal_Title"].Value,
            ["Body"] = L["EditTfe_CancelModal_Body"].Value,
            ["ConfirmText"] = L["EditTfe_CancelModal_Confirm"].Value,
            ["CancelText"] = L["EditTfe_ModalCancel"].Value,
            ["ConfirmColor"] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<TfeStatusConfirmDialog>(string.Empty, parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
            await ChangeStatusAsync(TfeStatus.Cancelled, L["EditTfe_CancelSuccess"].Value);
    }

    private async Task ChangeStatusAsync(TfeStatus status, string successMessage)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            var response = await client.PatchAsJsonAsync($"api/match/tfe/{Id}/status", new { Status = (int)status });

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(successMessage, Severity.Success);
                Navigation.NavigateTo("/tfe/author");
                return;
            }

            Snackbar.Add(L["EditTfe_StatusChangeError"].Value, Severity.Error);
        }
        catch
        {
            Snackbar.Add(L["EditTfe_StatusChangeError"].Value, Severity.Error);
        }
    }
}
