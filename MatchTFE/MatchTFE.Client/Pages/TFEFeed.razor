    @page "/tfe/feed"
@using TFELibrary.Shared
@using System.Net.Http.Json

@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory

<DiscoverLayout ActiveIndex="0"
                MobileTitle="Descubrir un proyecto"
                MobileButtonText="Buscar perfiles"
                MobileButtonIcon="@Icons.Material.Filled.People">

    @if (_proposalsQueue.Any())
    {
        var current = _proposalsQueue.Peek();

        <TfeCard Proposal="@current" />

        @* --- ACTION BUTTONS --- *@
        <MudPaper Elevation="0" Class="pa-4 rounded-xl app-actions-bar border-all mb-10">
            <div class="d-flex flex-column flex-sm-row align-center justify-center gap-3">
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Large"
                           OnClick="@(() => HandleActionAsync(false))"
                           Class="rounded-lg px-8 py-3 font-weight-bold w-100 w-sm-auto" StartIcon="@Icons.Material.Filled.Close">
                    DESCARTAR
                </MudButton>

                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large"
                           OnClick="@(() => HandleActionAsync(true))"
                           Class="rounded-lg px-8 py-3 font-weight-bold w-100 w-sm-auto" StartIcon="@Icons.Material.Filled.Favorite">
                    ME INTERESA
                </MudButton>
            </div>
        </MudPaper>
    }
    else
    {
        <div class="d-flex flex-column align-center justify-center mt-15 text-center">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Class="icon-huge mb-4" />
            <MudText Typo="Typo.h4" Class="font-weight-bold">¡Has visto todo por hoy!</MudText>
            <MudText Typo="Typo.body1" Class="mud-text-secondary mb-6">
                Parece que has revisado todas las propuestas por ahora.<br />Vuelve más tarde para ver nuevos proyectos.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => AppendTfesAsync(clearQueue: true)">Recargar Propuestas</MudButton>
        </div>
    }
</DiscoverLayout>

@code {
    private Queue<TfeDto> _proposalsQueue = new();
    private bool _isLoading = false;

    private const int LOAD_THRESHOLD = 2;
    private const int BATCH_SIZE = 10;

    protected override async Task OnInitializedAsync()
    {
        await AppendTfesAsync(clearQueue: true);
    }

    private async Task AppendTfesAsync(bool clearQueue = false)
    {
        if (_isLoading) return;

        _isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            var response = await client.GetFromJsonAsync<TfeRecommendedResponse>($"api/match/tfe/recommended?count={BATCH_SIZE}");

            if (clearQueue)
                _proposalsQueue.Clear();

            if (response?.Tfes != null)
                foreach (var tfe in response.Tfes)
                    _proposalsQueue.Enqueue(tfe);
        }
        catch
        {
            var errorMsg = clearQueue
                ? "Error al conectar con el backend al obtener los proyectos."
                : "Error al cargar más proyectos.";
            Snackbar.Add(errorMsg, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleActionAsync(bool isInterested)
    {
        if (!_proposalsQueue.Any()) return;
        var currentProposal = _proposalsQueue.Peek();

        var request = new TfeProposalCreationRequest
        {
            TfeId = currentProposal.Id,
            IsInterested = isInterested
        };

        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            var response = await client.PostAsJsonAsync("api/match/proposal/tfe", request);

            if (response.IsSuccessStatusCode)
            {

            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Snackbar.Add(errorMsg, Severity.Warning);
            }
            else
            {
                Snackbar.Add("Hubo un problema al registrar tu decisión.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Error de conexión al servidor.", Severity.Error);
        }
        finally
        {
            _proposalsQueue.Dequeue();
            StateHasChanged();

            if (_proposalsQueue.Count < LOAD_THRESHOLD && _proposalsQueue.Count > 0 && !_isLoading)
            {
                _ = AppendTfesAsync();
            }
        }
    }
}