@page "/profiles/feed"
@inject ISnackbar Snackbar
@using TFELibrary.Shared

<DiscoverLayout ActiveIndex="1"
                MobileTitle="Descubrir un candidato"
                MobileButtonText="Buscar Proyectos (TFEs)"
                MobileButtonIcon="@Icons.Material.Filled.Assignment">

    @if (_candidatesQueue.Any())
    {
        var current = _candidatesQueue.Peek();
        <ProfileCard @key="current.Id" Profile="@current" OnDecision="HandleAction" />
    }
    else
    {
        <div class="d-flex flex-column align-center justify-center mt-15 text-center">
            <MudIcon Icon="@Icons.Material.Filled.PeopleOutline" Class="icon-huge mb-4" />
            <MudText Typo="Typo.h4" Class="font-weight-bold">¡No hay más candidatos!</MudText>
            <MudText Typo="Typo.body1" Class="mud-text-secondary mb-6">
                Has revisado todos los perfiles disponibles por ahora.<br />Vuelve más tarde.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadMockData">Recargar Perfiles</MudButton>
        </div>
    }
</DiscoverLayout>

@code {
    private Queue<CandidateProfileDto> _candidatesQueue = new();

    protected override void OnInitialized() { LoadMockData(); }

    private void LoadMockData()
    {
        var mockData = new List<CandidateProfileDto>
        {
            new () {
                Id = 1,
                FullName = "Carlos Méndez Ruiz",
                Degree = "Grado en Ingeniería Informática",
                Location = "Madrid, España",
                AcademicYear = "4º Curso",
                AvatarUrl = "https://randomuser.me/api/portraits/men/32.jpg", // Cambiado a portrait de hombre
                AreasOfInterest = new() { "Inteligencia Artificial", "Machine Learning", "Ciberseguridad", "Computación en la Nube", "Blockchain", "DevOps" },
                Biography = "Estudiante de último año apasionado por la resolución de problemas complejos mediante el uso de algoritmos avanzados y arquitecturas de datos escalables. Durante mi formación académica, me he especializado en el desarrollo de sistemas distribuidos y modelos de aprendizaje profundo.\n\nHe participado activamente en varios proyectos de código abierto y hackatones nacionales, donde obtuve el primer puesto en el desafío de ciberseguridad de la UPM en 2023. Mi objetivo actual es aplicar mis conocimientos técnicos en un proyecto de investigación que combine el análisis de grandes volúmenes de datos con la mejora de la eficiencia energética en centros de datos.\n\nBusco un mentor que me guíe en la transición del mundo académico al profesional, con especial interés en metodologías ágiles y entornos de producción reales. Me considero una persona proactiva, con gran capacidad de aprendizaje.",
                Competencies = new()
                {
                    new() { Name = "Python / Data Science", Score = 5, MaxScore = 5 },
                    new() { Name = "Java / Enterprise Apps", Score = 4, MaxScore = 5 },
                    new() { Name = "SQL & NoSQL Databases", Score = 4, MaxScore = 5 },
                    new() { Name = "Docker / Kubernetes", Score = 3, MaxScore = 5 }
                }
            },
            new () {
                Id = 2,
                FullName = "Laura Sánchez",
                Degree = "Grado en Matemáticas e Informática",
                Location = "Valencia, España",
                AcademicYear = "4º Curso",
                AvatarUrl = "https://randomuser.me/api/portraits/women/68.jpg",
                AreasOfInterest = new() { "Criptografía", "Seguridad Web", "Desarrollo Backend", "Arquitectura de Software" },
                Biography = "Desarrolladora apasionada por la ciberseguridad, la infraestructura web y la optimización de algoritmos matemáticos aplicados a la computación.\n\nActualmente busco un Trabajo de Fin de Grado (TFG) enfocado en la securización de APIs y la implementación de protocolos de autenticación modernos (OAuth2.0, OpenID Connect) en entornos de alta concurrencia. \n\nSoy muy perfeccionista con el Clean Code y me encanta documentar bien todo el software que construyo.",
                Competencies = new()
                {
                    new() { Name = "C# / .NET Core", Score = 5, MaxScore = 5 },
                    new() { Name = "C++ / Algoritmia", Score = 4, MaxScore = 5 },
                    new() { Name = "React & TypeScript", Score = 3, MaxScore = 5 },
                    new() { Name = "Ciberseguridad Ofensiva", Score = 2, MaxScore = 5 }
                }
            },
            new () {
                Id = 3,
                FullName = "Alejandro Vargas",
                Degree = "Máster en Ingeniería de Software",
                Location = "Barcelona, España",
                AcademicYear = "1º Año (Máster)",
                AvatarUrl = "https://randomuser.me/api/portraits/men/85.jpg",
                AreasOfInterest = new() { "Desarrollo Frontend", "UX/UI Design", "Aplicaciones Móviles", "Realidad Aumentada" },
                Biography = "Mi gran pasión es la interacción persona-ordenador (HCI) y la creación de interfaces de usuario accesibles, rápidas y visualmente impactantes. Vengo de un background muy fuerte en diseño gráfico, pero me pasé a la programación para poder dar vida a mis propios diseños.\n\nBusco un proyecto que me permita explorar frameworks modernos como Flutter o Blazor, preferiblemente aplicado a algún sector social, educación o salud (HealthTech).",
                Competencies = new()
                {
                    new() { Name = "UI/UX (Figma)", Score = 5, MaxScore = 5 },
                    new() { Name = "Flutter / Dart", Score = 4, MaxScore = 5 },
                    new() { Name = "Blazor / WebAssembly", Score = 3, MaxScore = 5 },
                    new() { Name = "Bases de Datos Relacionales", Score = 2, MaxScore = 5 }
                }
            }
        };

        foreach (var c in mockData) _candidatesQueue.Enqueue(c);
    }

    private void HandleAction(bool isLike)
    {
        if (!_candidatesQueue.Any()) return;
        var processed = _candidatesQueue.Dequeue();
        StateHasChanged();
    }
}