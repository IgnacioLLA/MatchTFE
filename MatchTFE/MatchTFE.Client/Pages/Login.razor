@page "/login"
@using TFELibrary.Shared
@using System.Net.Http.Json
@layout AuthLayout

@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L

<MudCard Class="auth-card">
    <MudCardContent Class="auth-card-content">
        <form @onsubmit="HandleLoginAsync" @onsubmit:preventDefault>
        <MudText Typo="Typo.h5" Class="auth-title">@L["Login_Title"]</MudText>
        <MudText Typo="Typo.body2" Class="auth-subtitle">@L["Login_Subtitle"]</MudText>

        @if (_isSuspended)
        {
            <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.Block" Class="mb-4" Dense="true">
                @L["Login_SuspendedMessage"]
            </MudAlert>
        }
        else if (!string.IsNullOrEmpty(_loginError))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">
                @_loginError
            </MudAlert>
        }

        <MudTextField @bind-Value="_loginModel.Email"
                      Label="@L["Login_EmailLabel"]"
                      Placeholder="@L["Login_EmailPlaceholder"]"
                      Variant="Variant.Outlined"
                      InputType="InputType.Email"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Outlined.Email"
                      AutoComplete="email"
                      Class="auth-input"
                      Error="@(_emailError != null)"
                      ErrorText="@_emailError" />

        <div class="password-header">
            <MudText Typo="Typo.body2" Class="password-label">@L["Login_PasswordLabel"]</MudText>
            <MudLink Typo="Typo.caption" Underline="Underline.Hover" Class="forgot-link" @onclick="ToggleForgotPasswordInfo">@L["Login_ForgotPassword"]</MudLink>
        </div>

        @if (_showForgotPasswordInfo)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                @L["Login_ForgotPasswordInfo"]
            </MudAlert>
        }

        <MudTextField @bind-Value="_loginModel.Password"
                      Placeholder="••••••••"
                      Variant="Variant.Outlined"
                      InputType="@_passwordInput"
                      Adornment="Adornment.End"
                      AdornmentIcon="@_passwordIcon"
                      OnAdornmentClick="TogglePasswordVisibility"
                      AutoComplete="current-password"
                      Class="auth-input login-password-input"
                      Error="@(_passwordError != null)"
                      ErrorText="@_passwordError" />

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Disabled="@_isLoading"
                   Class="auth-button">
            @if (_isLoading)
            {
                <MudProgressCircular Indeterminate="true" Class="loading-spinner" />
                <span class="loading-text">@L["Login_Loading"]</span>
            }
            else
            {
                <span class="button-content">@L["Login_Submit"] <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="btn-icon" /></span>
            }
        </MudButton>

        <div class="auth-bottom-section">
            <MudText Typo="Typo.body2" Class="auth-bottom-text">@L["Login_NoAccount"]</MudText>
            <MudLink Href="/register" Typo="Typo.body2" Underline="Underline.Hover" Class="auth-bottom-link">@L["Login_CreateAccount"]</MudLink>
        </div>
        </form>
    </MudCardContent>
</MudCard>

@code {
    private LoginRequest _loginModel = new();
    private bool _isLoading = false;
    private bool _isSuspended = false;
    private string _loginError = string.Empty;
    private bool _showForgotPasswordInfo = false;

    private string? _emailError;
    private string? _passwordError;

    private InputType _passwordInput = InputType.Password;
    private string _passwordIcon = Icons.Material.Outlined.VisibilityOff;

    private void ToggleForgotPasswordInfo() => _showForgotPasswordInfo = !_showForgotPasswordInfo;

    private void TogglePasswordVisibility()
    {
        if (_passwordInput == InputType.Password)
        {
            _passwordInput = InputType.Text;
            _passwordIcon = Icons.Material.Outlined.Visibility;
        }
        else
        {
            _passwordInput = InputType.Password;
            _passwordIcon = Icons.Material.Outlined.VisibilityOff;
        }
    }

    private bool CheckForm()
    {
        _emailError = null;
        _passwordError = null;

        if (string.IsNullOrWhiteSpace(_loginModel.Email))
            _emailError = L["Login_EmailRequired"].Value;
        else if (!IsValidEmail(_loginModel.Email))
            _emailError = L["Login_EmailInvalid"].Value;

        if (string.IsNullOrWhiteSpace(_loginModel.Password))
            _passwordError = L["Login_PasswordRequired"].Value;

        return _emailError == null && _passwordError == null;
    }

    private static bool IsValidEmail(string email)
    {
        var at = email.IndexOf('@');
        if (at < 1 || email.IndexOf('@', at + 1) >= 0) return false;
        var domain = email[(at + 1)..];
        var dot = domain.LastIndexOf('.');
        return dot > 0 && dot < domain.Length - 1;
    }

    private async Task HandleLoginAsync()
    {
        if (!CheckForm()) return;

        _isLoading = true;
        _isSuspended = false;
        _loginError = string.Empty;

        try
        {
            var response = await ClientFactory.CreateClient("GatewayAPI").PostAsJsonAsync("api/auth/login", _loginModel);

            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/", replace: true);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                _emailError = L["Login_EmailInvalid"].Value;
            }
            else
            {
                var errorResult = await response.Content.ReadFromJsonAsync<LoginResponse>();

                if (errorResult?.Error?.ErrorCode == "AccountSuspended")
                    _isSuspended = true;
                else
                    _loginError = L["Login_ErrorDefault"].Value;
            }
        }
        catch (Exception)
        {
            _loginError = L["Login_ConnectionError"].Value;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
