@page "/match"
@using TFELibrary.Shared
@inject IHttpClientFactory HttpClientFactory

<MudContainer MaxWidth="MaxWidth.Large" Class="pt-4 px-4 px-sm-8 mb-10 animate-fade-in">

    <div class="d-flex align-center mb-6 mt-4">
        <MudText Typo="Typo.h3" Class="font-weight-bold">Mis Matches</MudText>
    </div>

    <MudText Typo="Typo.body1" Class="mud-text-secondary mb-8">
        Aquí puedes ver los proyectos de TFE y candidatos con los que has hecho match. Estos son los proyectos y perfiles que han aceptado tu propuesta.
    </MudText>

    @if (_isLoading)
    {
        <div class="pa-10 text-center">
            <MudProgressCircular Indeterminate="true" />
            <MudText Typo="Typo.body2" Class="mt-4">Cargando matches...</MudText>
        </div>
    }
    else if (!_tfeMatches.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mb-6">
            <MudText>Aún no tienes ningún match. Explora los proyectos o candidatos disponibles y muestra interés para crear matches.</MudText>
        </MudAlert>
    }
    else
    {
        <MudGrid Spacing="4" Class="mt-2">
            @foreach (var match in _tfeMatches)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="1" Class="pa-5 rounded-xl border-all h-100 d-flex flex-column">
                        <div class="d-flex align-start justify-space-between mb-3">
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Match Aceptado</MudChip>
                        </div>

                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-2 app-title-tight">@match.TfeTitle</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Class="mr-1" />
                            @match.MatchedUserFullName
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                            Tutor: @match.TfeTutorName
                        </MudText>

                        @if (!string.IsNullOrEmpty(match.MatchedUserDepartment))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Domain" Size="Size.Small" Class="mr-1" />
                                @match.MatchedUserDepartment
                            </MudText>
                        }

                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Class="mr-1" />
                            Match desde: @match.MatchDate.ToString("dd/MM/yyyy")
                        </MudText>

                        <MudSpacer />

                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Class="rounded-lg mt-4" StartIcon="@Icons.Material.Filled.Email" OnClick="@(() => ContactMatch(match))">
                            Contactar
                        </MudButton>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<AcceptedMatchDto> _tfeMatches = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAcceptedMatches();
    }

    private async Task LoadAcceptedMatches()
    {
        _isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            var response = await client.GetAsync("api/match/proposal/tfe/matches");

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<GetAcceptedMatchesResponse>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (result?.Success == true && result.Matches != null)
                {
                    _tfeMatches = result.Matches
                        .DistinctBy(m => m.TfeId)
                        .OrderByDescending(m => m.MatchDate)
                        .ToList();
                }
            }
            else
            {
                Console.WriteLine($"Error al cargar los matches. Status: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ContactMatch(AcceptedMatchDto match)
    {
        Console.WriteLine($"Contactando con {match.MatchedUserFullName} (Email: {match.MatchedUserEmail})");
    }
}