@page "/tfe/author"
@using TFELibrary.Shared
@using System.Net.Http.Json

@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject IStringLocalizer<SharedResources> L

<div class="mb-6 d-flex justify-space-between align-end animate-fade-in">
    <div>
        <MudText Typo="Typo.h4" Class="app-title-tight mb-2 font-weight-extrabold">
            @L["MyTfes_Title"]
        </MudText>
        <MudText Typo="Typo.body1" Class="mud-text-secondary">
            @L["MyTfes_Subtitle"]
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.AddCircleOutline"
               Class="rounded-lg font-weight-bold px-4 py-2 btn-primary-shadow"
               Href="/tfe/create">
        @L["MyTfes_CreateBtn"]
    </MudButton>
</div>

<MudPaper Elevation="0" Class="border-all rounded-xl animate-fade-in">

    @* FILTERS *@
    <div class="pa-4 d-flex flex-wrap gap-4 align-center tfe-filter-section">
        <MudTextField @bind-Value="SearchQuery"
                      Placeholder="@L["MyTfes_SearchPlaceholder"]"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Class="rounded-lg flex-grow-1 tfe-search-input" />

        <MudSelect T="string"
                   MultiSelection="true"
                   SelectedValues="SelectedFilterTags"
                   SelectedValuesChanged="OnSelectedTagsChanged"
                   Placeholder="@L["MyTfes_FilterByTags"]"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Class="rounded-lg flex-grow-1 tfe-filter-select">
            @foreach (var tag in _availableTags)
            {
                <MudSelectItem Value="@tag.Name">@tag.Name</MudSelectItem>
            }
        </MudSelect>

        <div class="d-flex align-center">
            <MudText Typo="Typo.body2" Class="mud-text-secondary mr-2">@L["MyTfes_FilterByStatus"]</MudText>
            <MudSelect T="string" @bind-Value="StatusFilter" Variant="Variant.Text" Margin="Margin.Dense" Class="font-weight-bold" Style="min-width: 140px;">
                <MudSelectItem Value="@("all")">@L["MyTfes_FilterStatus_All"]</MudSelectItem>
                <MudSelectItem Value="@("open")">@L["MyTfes_FilterStatus_Open"]</MudSelectItem>
                <MudSelectItem Value="@("completed")">@L["MyTfes_FilterStatus_Completed"]</MudSelectItem>
            </MudSelect>
        </div>

        <MudSpacer />

        <div class="d-flex align-center">
            <MudText Typo="Typo.body2" Class="mud-text-secondary mr-2">@L["MyTfes_SortBy"]</MudText>
            <MudSelect T="string" @bind-Value="SelectedSort" Variant="Variant.Text" Margin="Margin.Dense" Class="font-weight-bold">
                <MudSelectItem Value="@("newest")">@L["MyTfes_SortNewest"]</MudSelectItem>
                <MudSelectItem Value="@("oldest")">@L["MyTfes_SortOldest"]</MudSelectItem>
                <MudSelectItem Value="@("status")">@L["MyTfes_SortStatus"]</MudSelectItem>
                <MudSelectItem Value="@("creation")">@L["MyTfes_SortCreation"]</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    @* TABLE HEADERS *@
    <div class="px-6 py-3 mud-text-secondary font-weight-bold tfe-column-headers d-none d-md-block">
        <MudGrid>
            <MudItem xs="12" md="3">@L["MyTfes_ColProject"]</MudItem>
            <MudItem xs="6" md="2">@L["MyTfes_ColStatus"]</MudItem>
            <MudItem xs="6" md="2">@L["MyTfes_ColExpiry"]</MudItem>
            <MudItem xs="6" md="2">@L["MyTfes_ColInterested"]</MudItem>
            <MudItem xs="12" md="2">@L["MyTfes_ColCreation"]</MudItem>
            <MudItem xs="12" md="1" Class="d-flex justify-end">@L["MyTfes_ColActions"]</MudItem>
        </MudGrid>
    </div>
    <MudDivider Class="d-none d-md-block" />

    @* ITEMS LIST *@
    <div class="px-6">
        @foreach (var proposal in GetPaginatedProposals())
        {
            <TfeListItem Model="proposal" OnDeleted="HandleDeleteProposal" />
        }
    </div>

    @* FOOTER *@
    <div class="pa-4 d-flex justify-space-between align-center tfe-footer-section">
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            @L["MyTfes_ShowingOf", GetPaginatedProposals().Count(), GetFilteredProposals().Count()]
        </MudText>
        <MudPagination Count="@GetTotalPages()"
                       @bind-Selected="_currentPage"
                       Color="Color.Primary"
                       Variant="Variant.Outlined"
                       />
    </div>

</MudPaper>

@code {
    private List<TfeDto> _proposals = new();
    private List<TagDto> _availableTags = new();

    private int _currentPage = 1;
    private int _pageSize = 10;

    private string _searchQuery = string.Empty;
    public string SearchQuery
    {
        get => _searchQuery;
        set
        {
            _searchQuery = value;
            _currentPage = 1;
        }
    }

    private IReadOnlyCollection<string> SelectedFilterTags { get; set; } = new HashSet<string>();

    private string _selectedSort = "newest";
    public string SelectedSort
    {
        get => _selectedSort;
        set
        {
            _selectedSort = value;
            _currentPage = 1;
        }
    }

    private string _statusFilter = "all";
    public string StatusFilter
    {
        get => _statusFilter;
        set
        {
            _statusFilter = value;
            _currentPage = 1;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            _proposals = await client.GetFromJsonAsync<List<TfeDto>>("api/match/tfe/author") ?? new();
            _availableTags = await client.GetFromJsonAsync<List<TagDto>>("api/match/tag") ?? new();
        }
        catch { }
    }

    private IEnumerable<TfeDto> GetFilteredProposals()
    {
        var result = _proposals.AsEnumerable();

        result = StatusFilter switch
        {
            "completed" => result.Where(p => p.Status == TfeStatus.Completed),
            "open"      => result.Where(p => p.Status == TfeStatus.Open),
            _           => result
        };

        if (!string.IsNullOrWhiteSpace(SearchQuery))
        {
            result = result.Where(p =>
                (p.Title != null && p.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)) ||
                (p.Topics != null && p.Topics.Any(t => t.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)))
            );
        }

        if (SelectedFilterTags != null && SelectedFilterTags.Any())
        {
            result = result.Where(p =>
                p.Topics != null && p.Topics.Any(t => SelectedFilterTags.Contains(t.Name))
            );
        }

        result = SelectedSort switch
        {
            "oldest" => result.OrderBy(p => p.ExpirationDate),
            "status" => result.OrderBy(p => p.Status),
            "creation" => result.OrderByDescending(p => p.CreationDate),
            _ => result.OrderByDescending(p => p.ExpirationDate)
        };

        return result;
    }

    private IEnumerable<TfeDto> GetPaginatedProposals()
    {
        return GetFilteredProposals()
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize);
    }

    private int GetTotalPages()
    {
        var totalItems = GetFilteredProposals().Count();
        if (totalItems == 0) return 1;
        return (int)Math.Ceiling((double)totalItems / _pageSize);
    }

    private void OnSelectedTagsChanged(IReadOnlyCollection<string> values)
    {
        SelectedFilterTags = values ?? new HashSet<string>();
        _currentPage = 1;
        StateHasChanged();
    }

    private async Task HandleDeleteProposal(int tfeId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("GatewayAPI");
            var response = await client.DeleteAsync($"api/match/tfe/{tfeId}");

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(L["MyTfes_DeleteSuccess"].Value, Severity.Success);

                _proposals.RemoveAll(p => p.Id == tfeId);

                var maxPages = GetTotalPages();
                if (_currentPage > maxPages && maxPages > 0)
                {
                    _currentPage = maxPages;
                }

                StateHasChanged();
            }
            else
            {
                Snackbar.Add(L["MyTfes_DeleteError"].Value, Severity.Error);
            }
        }
        catch { }
    }
}
