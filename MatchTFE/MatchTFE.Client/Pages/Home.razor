@page "/"

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-8 px-4 px-sm-8">
    
    @* 1. Bienvenida *@
    <div class="mb-8">
        <MudText Typo="Typo.h3" Class="mb-2">¡Hola, Dr. Rodríguez!</MudText>
        <MudText Typo="Typo.h6" Class="mud-text-secondary">¡Es un buen día para encontrar al candidato ideal!</MudText>
    </div>

    <MudGrid>
        <MudItem xs="12" md="8">
            
            @* 2. Stats: xs="12" hace que en móvil ocupen todo el ancho (columna) *@
            <MudGrid Class="mb-8">
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="1" Class="pa-4 rounded-lg">
                        <MudText Typo="Typo.h4"><b>14</b></MudText>
                        <MudText Typo="Typo.caption">Propuestas nuevas hoy</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="1" Class="pa-4 rounded-lg">
                        <MudText Typo="Typo.h4"><b>5</b></MudText>
                        <MudText Typo="Typo.caption">Matches confirmados</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="1" Class="pa-4 rounded-lg">
                        <MudText Typo="Typo.h4"><b>3</b></MudText>
                        <MudText Typo="Typo.caption">Solicitudes pendientes</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @* 3. Recomendados *@
            <MudText Typo="Typo.h6" Class="mb-4">Recomendados para ti</MudText>
            <MudGrid Class="mb-8">
                @foreach(var candidato in _recomendados)
                {
                    @* También en columna en móvil (xs=12) *@
                    <MudItem xs="12" sm="4">
                        <MudPaper Elevation="1" Class="pa-4 rounded-lg text-center">
                            <MudAvatar Size="Size.Large" Class="mb-2">@candidato.Nombre[0]</MudAvatar>
                            <MudText Typo="Typo.body1"><b>@candidato.Nombre</b></MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@candidato.Afinidad% Afinidad</MudChip>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>

            @* 4. CTA: flex-column en móvil, flex-row en escritorio *@
            <MudPaper Elevation="2" Class="pa-6 pa-sm-8 rounded-lg d-flex flex-column flex-sm-row align-center justify-space-between">
                <div class="mb-4 mb-sm-0 text-center text-sm-start">
                    <MudText Typo="Typo.h5"><b>¿Buscas algo específico?</b></MudText>
                    <MudText Typo="Typo.body1">Explora cientos de perfiles y propuestas ahora.</MudText>
                </div>
                <MudButton Variant="Variant.Filled" Size="Size.Large" 
                           Href="/tfe-feed" Class="px-10 py-3">
                    Empezar a buscar ahora
                </MudButton>
            </MudPaper>
        </MudItem>

        @* COLUMNA LATERAL (Alertas y Onboarding) *@
        <MudItem xs="12" md="4">
             @if (_porcentajePerfil < 100)
            {
                <MudPaper Elevation="1" Class="pa-6 rounded-lg mb-6">
                    <MudText Typo="Typo.subtitle2"><b>Completa tu perfil</b></MudText>
                    <MudProgressLinear Value="_porcentajePerfil" Class="my-3" Size="Size.Large">
                        <MudText Typo="Typo.caption"><b>@_porcentajePerfil%</b></MudText>
                    </MudProgressLinear>
                </MudPaper>
            }

            <MudPaper Elevation="1" Class="pa-6 rounded-lg mb-6">
                <MudText Typo="Typo.subtitle2" Class="mb-4"><b>Alertas</b></MudText>
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-3" Size="Size.Small"/>
                    <MudText Typo="Typo.caption">La propuesta "IA" caduca en 2 días.</MudText>
                </div>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-6 rounded-lg">
                <MudText Typo="Typo.subtitle2" Class="mb-4"><b>Últimos Matches</b></MudText>
                <MudAvatarGroup Max="3" Spacing="3">
                    <MudAvatar Image="https://randomuser.me/api/portraits/men/1.jpg" />
                    <MudAvatar Image="https://randomuser.me/api/portraits/women/2.jpg" />
                    <MudAvatar Image="https://randomuser.me/api/portraits/men/3.jpg" />
                </MudAvatarGroup>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private int _porcentajePerfil = 75;
    private List<CandidatoSimplificado> _recomendados = new()
    {
        new ("Carlos M.", 98),
        new ("Lucía S.", 92),
        new ("David R.", 85)
    };
    public record CandidatoSimplificado(string Nombre, int Afinidad);
}