@page "/"
@using MatchTFE.Client.Components.Home

@inject IStringLocalizer<SharedResources> L

<main class="home-root animate-fade-in" aria-label="Inicio de MATCH-TFE">
    @if (GlobalProfile == null)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    }
    else if (GlobalProfile.Role == RoleType.Admin)
    {
        <AdminHomePanel />
    }
    else if (GlobalProfile.Role == RoleType.Teacher)
    {
        <TeacherHomePanel />
    }
    else if (GlobalProfile.Role == RoleType.Student)
    {
        <StudentHomePanel />
    }
    else
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @L["Home_RoleError"]
        </MudAlert>
    }
</main>

@code {
    [CascadingParameter] public ProfileDto? GlobalProfile { get; set; }
}
