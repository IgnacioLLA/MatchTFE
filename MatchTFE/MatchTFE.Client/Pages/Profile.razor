@page "/profile"
@using Microsoft.AspNetCore.Components.WebAssembly.Http
@using TFELibrary.Shared
@using System.Text.Json

@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> L

@if (_isLoading || _profileDto == null)
{
    <div class="d-flex justify-center align-center center-height-50vh">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="ml-4 mud-text-secondary">@L["Profile_Loading"]</MudText>
    </div>
}
else
{
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h5" Class="font-weight-extrabold">
            @L["Profile_Title"]
        </MudText>
    </div>

    <div class="animate-fade-in">
        <MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-4">
            <MudCardContent Class="d-flex align-center flex-wrap gap-4">
                <MudAvatar Color="Color.Primary" Class="avatar-xl font-weight-bold">
                    @($"{GlobalProfile?.FirstName?.FirstOrDefault()}{GlobalProfile?.LastName?.FirstOrDefault()}".ToUpper())
                </MudAvatar>
                <div class="flex-grow-1">
                    <MudText Typo="Typo.h5" Class="app-title-tight mb-1">@_profileDto.FirstName @_profileDto.LastName</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                        @GetRoleDescription(_profileDto.Role)
                    </MudText>
                </div>
            </MudCardContent>
        </MudCard>

        @* PERSONAL DATA *@
        <MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-2">
            <MudCardHeader>
                <CardHeaderAvatar><MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" /></CardHeaderAvatar>
                <CardHeaderContent><MudText Typo="Typo.h6" Class="font-weight-bold">@L["Profile_PersonalData"]</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_profileDto.FirstName"
                                      Label="@L["Profile_Name"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="rounded-lg"
                                      ReadOnly="true"/>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_profileDto.LastName"
                                      Label="@L["Profile_LastName"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="rounded-lg"
                                      ReadOnly="true"/>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_profileDto.Email"
                                      Label="@L["Profile_InstitutionalEmail"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      ReadOnly="true"
                                      Class="rounded-lg"
                                      HelperText="@L["Profile_EmailHelper"]" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_profileDto.Bio"
                                      Label="@L["Profile_Bio"]"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      Class="rounded-lg"
                                      HelperText="@L["Profile_BioHelper"]" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        @if (!IsAdmin)
        {
            @* NOTIFICATIONS *@
            <MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-2">
                <MudCardHeader>
                    <CardHeaderAvatar><MudIcon Icon="@Icons.Material.Filled.Notifications" Color="Color.Primary" /></CardHeaderAvatar>
                    <CardHeaderContent><MudText Typo="Typo.h6" Class="font-weight-bold">@L["Profile_Notifications"]</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudSelect @bind-Value="_profileDto.NotificationFrequency"
                               Label="@L["Profile_NotificationFrequency"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="rounded-lg"
                               HelperText="@L["Profile_NotificationFrequencyHelper"]">
                        <MudSelectItem Value="NotificationFrequency.Disabled">@L["Profile_NotifDisabled"]</MudSelectItem>
                        <MudSelectItem Value="NotificationFrequency.Weekly">@L["Profile_NotifWeekly"]</MudSelectItem>
                        <MudSelectItem Value="NotificationFrequency.Biweekly">@L["Profile_NotifBiweekly"]</MudSelectItem>
                        <MudSelectItem Value="NotificationFrequency.Monthly">@L["Profile_NotifMonthly"]</MudSelectItem>
                    </MudSelect>
                </MudCardContent>
            </MudCard>

            @* INTERESTS *@
            <MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-2"
                     Style="@(_profileDto.Interests.Count == 0 ? "border-color: var(--mud-palette-warning) !important; border-left: 4px solid var(--mud-palette-warning) !important; background: rgba(var(--mud-palette-warning-rgb), 0.05);" : "")">
                <MudCardContent>
                    @if (_profileDto.Interests.Count == 0)
                    {
                        <div class="d-flex align-center gap-2 mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.TipsAndUpdates" Color="Color.Warning" Size="Size.Small" />
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-warning-darken);">
                                @L["Profile_NoInterestsWarning"]
                            </MudText>
                        </div>
                    }
                    <TagSelector @bind-SelectedTags="_profileDto.Interests"
                                 Title="@L["Profile_Interests"]"
                                 Icon="@Icons.Material.Filled.LocalOffer"
                                 Placeholder="@L["Profile_InterestsPlaceholder"]" />
                    <MudText Typo="Typo.caption" Class="app-text-muted mt-2">
                        @L["Profile_InterestsHelper"]
                    </MudText>
                </MudCardContent>
            </MudCard>

            @if (IsStudent)
            {
                <StudentProfileComponent Model="_profileDto" />
            }
            else if (IsTeacher)
            {
                <TeacherProfileComponent Model="_profileDto" />
            }
        }

        @* ACTION BUTTONS *@
        <div class="d-flex align-center justify-space-between mt-8 mb-4">
            <div class="d-flex gap-4">
                <MudButton Variant="Variant.Text"
                           Color="Color.Default"
                           Class="font-weight-bold"
                           OnClick="DiscardChanges">
                    @L["Profile_Discard"]
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           DropShadow="false"
                           Class="rounded-lg font-weight-bold px-6"
                           OnClick="SaveChanges">
                    @L["Profile_SaveChanges"]
                </MudButton>
            </div>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       DropShadow="false"
                       Class="rounded-lg font-weight-bold px-6"
                       OnClick="Logout"
                       aria-label="@L["Profile_Logout"]">
                @L["Profile_Logout"]
            </MudButton>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    public ProfileDto? GlobalProfile { get; set; }

    private ProfileDto? _profileDto = null;
    private bool _isLoading = true;
    private string _interestSearchQuery = string.Empty;

    private bool IsAdmin => _profileDto?.Role == RoleType.Admin;
    private bool IsStudent => _profileDto?.Role == RoleType.Student;
    private bool IsTeacher => _profileDto?.Role == RoleType.Teacher;

    private List<string> _availableBackendSkills = new();
    private List<string> _availableBackendInterests = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (GlobalProfile != null)
            {
                var json = JsonSerializer.Serialize(GlobalProfile);
                _profileDto = JsonSerializer.Deserialize<ProfileDto>(json);
            }

            await LoadTagsAsync();
        }
        catch { }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadTagsAsync()
    {
        try
        {
            var client = ClientFactory.CreateClient("GatewayAPI");
            var tags = await client.GetFromJsonAsync<List<TagDto>>("api/match/tag");

            if (tags != null)
            {
                _availableBackendInterests = tags.Select(t => t.Name).ToList();
                _availableBackendSkills = tags.Select(t => t.Name).ToList();
            }
        }
        catch { }
    }

    private async Task<IEnumerable<string>> SearchInterestsAsync(string value, CancellationToken token)
    {
        await Task.Delay(100, token);
        if (_profileDto == null) return Array.Empty<string>();
        if (string.IsNullOrEmpty(value)) return _availableBackendInterests.Where(t => !_profileDto.Interests.Contains(t));
        return _availableBackendInterests.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase) && !_profileDto.Interests.Contains(x));
    }

    private void OnInterestSelected(string selectedTag)
    {
        if (_profileDto != null && !string.IsNullOrEmpty(selectedTag) && !_profileDto.Interests.Contains(selectedTag))
            _profileDto.Interests.Add(selectedTag);

        _interestSearchQuery = string.Empty;
    }

    private void RemoveInterest(string tagToRemove)
    {
        _profileDto?.Interests.Remove(tagToRemove);
    }

    private void DiscardChanges()
    {
        if (GlobalProfile != null)
        {
            var json = JsonSerializer.Serialize(GlobalProfile);
            _profileDto = JsonSerializer.Deserialize<ProfileDto>(json);
            }
    }

    private async Task SaveChanges()
    {
        _isLoading = true;
        try
        {
            var client = ClientFactory.CreateClient("GatewayAPI");
            var request = new ProfileUpdateRequest(_profileDto!);
            var response = await client.PutAsJsonAsync("api/user/profile", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ProfileUpdateResponse>();
                if (result != null && result.Error.IsSuccess && result.UpdatedProfile != null)
                {
                    SyncGlobalProfile(result.UpdatedProfile);
                    _profileDto = result.UpdatedProfile;
                    Snackbar.Add(L["Profile_SavedSuccess"].Value, Severity.Success);
                }
                else
                {
                    Snackbar.Add(result?.Error.Message ?? L["Profile_SaveError"].Value, Severity.Warning);
                }
            }
            else
            {
                Snackbar.Add(L["Profile_SaveError"].Value, Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add(L["Profile_SaveError"].Value, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task Logout()
    {
        _isLoading = true;
        try
        {
            var client = ClientFactory.CreateClient("GatewayAPI");
            var response = await client.PostAsJsonAsync("api/auth/logout", new ProfileLogoutRequest());
            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/login");
            }
        }
        catch { }
        finally
        {
            _isLoading = false;
        }
    }

    private void SyncGlobalProfile(ProfileDto updatedProfile)
    {
        if (GlobalProfile == null) return;

        GlobalProfile.FirstName = updatedProfile.FirstName;
        GlobalProfile.LastName = updatedProfile.LastName;
        GlobalProfile.Email = updatedProfile.Email;
        GlobalProfile.Bio = updatedProfile.Bio;
        GlobalProfile.Role = updatedProfile.Role;
        GlobalProfile.Department = updatedProfile.Department;
        GlobalProfile.OfficeLocation = updatedProfile.OfficeLocation;
        GlobalProfile.AcademicYear = updatedProfile.AcademicYear;
        GlobalProfile.Interests = new List<string>(updatedProfile.Interests);
        GlobalProfile.Skills = updatedProfile.Skills.Select(s => new SkillDto
        {
            Tag = s.Tag,
            Level = s.Level
        }).ToList();
        GlobalProfile.NotificationFrequency = updatedProfile.NotificationFrequency;
    }

    private string GetRoleDescription(RoleType role) => role switch
    {
        RoleType.Student => L["Role_StudentDesc"].Value,
        RoleType.Teacher => L["Role_TeacherDesc"].Value,
        RoleType.Admin => L["Role_AdminDesc"].Value,
        _ => L["Role_User"].Value
    };
}
