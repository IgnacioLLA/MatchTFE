@page "/profile"
@using Microsoft.AspNetCore.Components.WebAssembly.Http
@using TFELibrary.Shared
@using System.Text.Json

@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

@if (_isLoading || _profileDto == null)
{
    <div class="d-flex justify-center align-center" style="height: 50vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="ml-4 mud-text-secondary">Cargando perfil...</MudText>
    </div>
}
else
{
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h5" Class="font-weight-extrabold">
            Mi Perfil
        </MudText>
    </div>

    <div class="animate-fade-in">
        <MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-4">
            <MudCardContent Class="d-flex align-center flex-wrap gap-4">
                <MudAvatar Color="Color.Primary" Class="avatar-xl font-weight-bold">
                    @if (!string.IsNullOrEmpty(GlobalProfile?.AvatarUrl))
                    {
                        <MudImage Src="@GlobalProfile.AvatarUrl" Alt="Foto de perfil" />
                    }
                    else
                    {
                        @($"{GlobalProfile?.FirstName?.FirstOrDefault()}{GlobalProfile?.LastName?.FirstOrDefault()}".ToUpper())
                    }
                </MudAvatar>
                <div class="flex-grow-1">
                    <MudText Typo="Typo.h5" Class="app-title-tight mb-1">@_profileDto.FirstName @_profileDto.LastName</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                        @(_profileDto.Role == RoleType.Student ? "Estudiante de Ingeniería Informática" : "Profesor Universitario")
                    </MudText>
                </div>
            </MudCardContent>
        </MudCard>

        @* PERSONAL DATA *@
        <MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-2">
            <MudCardHeader>
                <CardHeaderAvatar><MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" /></CardHeaderAvatar>
                <CardHeaderContent><MudText Typo="Typo.h6" Class="font-weight-bold">Datos Personales</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_profileDto.FirstName" Label="NOMBRE" Variant="Variant.Outlined" Margin="Margin.Dense" Class="rounded-lg" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_profileDto.LastName" Label="APELLIDOS" Variant="Variant.Outlined" Margin="Margin.Dense" Class="rounded-lg" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_profileDto.Email" Label="EMAIL INSTITUCIONAL" Variant="Variant.Filled" Margin="Margin.Dense" Disabled="true" Class="rounded-lg" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_profileDto.Bio" Label="BIOGRAFÍA / SOBRE MÍ" Variant="Variant.Outlined" Lines="4" Class="rounded-lg" HelperText="Preséntate a posibles compañeros de proyecto o tutores." />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        @* INTERESTS *@
        <MudCard Elevation="0" Class="border-all rounded-xl mb-6 pa-2">
            <MudCardContent>
                <TagSelector @bind-SelectedTags="_profileDto.Interests"
                             Title="Intereses"
                             Icon="@Icons.Material.Filled.LocalOffer"
                             Placeholder="Buscar intereses..." />
            </MudCardContent>
        </MudCard>

        @if (_profileDto.Role == RoleType.Student)
        {
            <StudentProfileComponent Model="_profileDto" />
        }
        else if (_profileDto.Role == RoleType.Teacher)
        {
            <TeacherProfileComponent Model="_profileDto" />
        }

        @* ACTION BUTTONS *@
        <div class="d-flex align-center justify-space-between mt-8 mb-4">
            <div class="d-flex gap-4">
                <MudButton Variant="Variant.Text" Color="Color.Default" Class="font-weight-bold" OnClick="DiscardChanges">Descartar</MudButton>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" DisableElevation="true" Class="rounded-lg font-weight-bold px-6" OnClick="SaveChanges">
                    Guardar Cambios
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Warning" DisableElevation="true" Class="rounded-lg font-weight-bold px-6" OnClick="Logout">
                    Cerrar sesión
                </MudButton>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    public ProfileDto? GlobalProfile { get; set; }

    private ProfileDto? _profileDto = null;
    private bool _isLoading = true;
    private string _interestSearchQuery = string.Empty;

    private List<string> _availableBackendSkills = new();
    private List<string> _availableBackendInterests = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (GlobalProfile != null)
            {
                var json = JsonSerializer.Serialize(GlobalProfile);
                _profileDto = JsonSerializer.Deserialize<ProfileDto>(json);
            }
            else
            {
                Snackbar.Add("Profile data not found.", Severity.Warning);
            }

            await LoadTagsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadTagsAsync()
    {
        try
        {
            var client = ClientFactory.CreateClient("GatewayAPI");
            var tags = await client.GetFromJsonAsync<List<TagDto>>("api/match/tag");

            if (tags != null)
            {
                _availableBackendInterests = tags.Select(t => t.Name).ToList();
                _availableBackendSkills = tags.Select(t => t.Name).ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading tags: {ex.Message}", Severity.Warning);
        }
    }

    private async Task<IEnumerable<string>> SearchInterestsAsync(string value, CancellationToken token)
    {
        await Task.Delay(100, token);
        if (_profileDto == null) return Array.Empty<string>();
        if (string.IsNullOrEmpty(value)) return _availableBackendInterests.Where(t => !_profileDto.Interests.Contains(t));
        return _availableBackendInterests.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase) && !_profileDto.Interests.Contains(x));
    }

    private void OnInterestSelected(string selectedTag)
    {
        if (_profileDto != null && !string.IsNullOrEmpty(selectedTag) && !_profileDto.Interests.Contains(selectedTag))
            _profileDto.Interests.Add(selectedTag);

        _interestSearchQuery = string.Empty;
    }

    private void RemoveInterest(string tagToRemove)
    {
        _profileDto?.Interests.Remove(tagToRemove);
    }

    private void DiscardChanges()
    {
        if (GlobalProfile != null)
        {
            var json = JsonSerializer.Serialize(GlobalProfile);
            _profileDto = JsonSerializer.Deserialize<ProfileDto>(json);
            Snackbar.Add("Changes discarded.", Severity.Info);
        }
    }

    private async Task SaveChanges()
    {
        _isLoading = true;
        try
        {
            var client = ClientFactory.CreateClient("GatewayAPI");
            var request = new ProfileUpdateRequest(_profileDto!);
            var response = await client.PutAsJsonAsync("api/user/profile", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ProfileUpdateResponse>();
                if (result != null && result.Success && result.UpdatedProfile != null)
                {
                    SyncGlobalProfile(result.UpdatedProfile);
                    _profileDto = result.UpdatedProfile;
                    Snackbar.Add("Profile updated!", Severity.Success);
                }
                else
                {
                    Snackbar.Add(result?.Message ?? "Error processing response.", Severity.Warning);
                }
            }
            else
            {
                Snackbar.Add($"HTTP error: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Connection error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task Logout()
    {
        _isLoading = true;
        try
        {
            var client = ClientFactory.CreateClient("GatewayAPI");
            var response = await client.PostAsJsonAsync("api/auth/logout", new ProfileLogoutRequest());
            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add($"HTTP error: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Connection error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SyncGlobalProfile(ProfileDto updatedProfile)
    {
        if (GlobalProfile == null) return;

        GlobalProfile.FirstName = updatedProfile.FirstName;
        GlobalProfile.LastName = updatedProfile.LastName;
        GlobalProfile.Email = updatedProfile.Email;
        GlobalProfile.Bio = updatedProfile.Bio;
        GlobalProfile.Role = updatedProfile.Role;
        GlobalProfile.Department = updatedProfile.Department;
        GlobalProfile.OfficeLocation = updatedProfile.OfficeLocation;
        GlobalProfile.AcademicYear = updatedProfile.AcademicYear;
        GlobalProfile.Interests = new List<string>(updatedProfile.Interests);
        GlobalProfile.Skills = updatedProfile.Skills.Select(s => new SkillDto
        {
            Tag = s.Tag,
            Level = s.Level
        }).ToList();
    }
}